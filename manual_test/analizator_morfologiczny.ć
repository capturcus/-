# Przekład gćć-python/morph_anal.py na Ć.
#
# Kontenery i Rezultat pochodzą z przygrywki (Lista to Ogniwo albo Nic,
# Sukces/Błąd), podział tekstu po separatorze z operacje_tekstowe.ć.
# Słownik to lista Haseł (klucz, zawartość); wstawienie nowego Hasła
# przesłania stare (semantyka assoc-listy zamiast dict.setdefault+update).
#
# Świadome uproszczenia względem pierwowzoru:
# - kanonizować działa na pojedynczym słowie (segmentacja po "_" i wielkich
#   literach to operacje tekstowe poza zakresem przekładu),
# - pominięta poprawka lematów imiesłowów (cytaty) — wymaga kluczy złożonych,
# - pominięty skrót "czasownik nie ma morfologii" oraz scalanie przypadków
#   przyimków (wstawiamy nowsze hasło zamiast sumować zbiory).

uwzględnij przygrywka.ć
uwzględnij operacje_tekstowe.ć

definicja Hasła z klucza na zawartość:
    klucz (klucz)
    zawartość (zawartość)

# Odpowiednik MorphAnalysis (NamedTuple); "napis" to forma powierzchniowa,
# którą Python trzyma jako klucz w db — tu nosimy ją w analizie.
definicja Analizy:
    napis (Tekst)
    klasa (Tekst)
    lemat (Tekst)
    etykieta (Tekst)
    kwalifikator (Tekst)
    przypadki (Lista o elemencie Tekst)
    liczba (Rezultat o elemencie Tekst)
    rodzaje (Lista o elemencie Tekst)

# Wynik _morpho_for_tag: (case, number, gender).
definicja Morfologii:
    przypadki (Lista o elemencie Tekst)
    liczba (Rezultat o elemencie Tekst)
    rodzaje (Lista o elemencie Tekst)

# Odpowiednik pary (db, preps) zwracanej przez load().
definicja Bazy:
    formy (Lista o elemencie (Hasło o kluczu Tekst o zawartości (Lista o elemencie Analiza)))
    przyimki (Lista o elemencie (Hasło o kluczu Tekst o zawartości (Lista o elemencie Tekst)))

# Odpowiednik tokenu po analyze(): słowo + analizy z bazy.
definicja OpisanegoSłowa:
    słowo (Tekst)
    analizy (Lista o elemencie Analiza)


# ---------- operacje na listach ----------

aby dodać element do listy:
    zwróć Ogniwo o głowie element o ogonie lista

aby brać_pierwszą z listy:
    gdy lista jest:
        Niczym:
            zwróć Błąd o opisie "lista jest pusta"
        Ogniwem z głową:
            zwróć Sukces o wartości głowa

# Element o zadanej pozycji, licząc od ZERA — jak indeksy w pythonowym
# pierwowzorze (przygrywkowe `wskazać` liczy od jedynki).
aby wybrać pozycję z listy:
    gdy lista jest:
        Niczym:
            zwróć Błąd o opisie "pozycja poza listą"
        Ogniwem z głową z ogonem:
            jeśli pozycja równe zero:
                zwróć Sukces o wartości głowa
            poprzednia to pozycja minus jeden
            zwróć wybierz poprzednią z ogona

aby należeć element do zbioru:
    gdy zbiór jest:
        Niczym:
            zwróć fałsz
        Ogniwem z głową z ogonem:
            jeśli głowa równe element:
                zwróć prawda
            zwróć należy element do ogona

# Przecięcie listy ze zbiorem (Python: frozenset(p for p in atoms if p in CASES)).
aby filtrować atomy według zbioru:
    gdy atomy są:
        Niczym:
            zwróć atomy
        Ogniwem z głową z ogonem:
            reszta to filtruj ogon według zbioru
            jeśli należy głowa do zbioru:
                zwróć dodaj głowę do reszty
            zwróć resztę

aby ignorować rzecz:
    zwróć


# ---------- opcja ----------

aby wydobyć opcję z awaryjną:
    gdy opcja jest:
        Sukcesem z wartością:
            zwróć wartość
        Błędem:
            zwróć awaryjną


# ---------- słownik (assoc-lista Haseł) ----------

aby szukać klucza w słowniku:
    gdy słownik jest:
        Niczym:
            zwróć Błąd o opisie "nie znaleziono klucza"
        Ogniwem z głową z ogonem:
            jeśli klucz głowy równe klucz:
                zwróć Sukces o wartości zawartość głowy
            zwróć szukaj klucza w ogonie

aby wstawić klucz z zawartością do słownika:
    zwróć dodaj (Hasło o kluczu klucz o zawartości zawartość) do słownika

# Mapowanie atomów rodzaju przez GENDER_MAP — zbiera tylko trafienia.
aby tłumaczyć atomy przez mapę:
    gdy atomy są:
        Niczym:
            zwróć atomy
        Ogniwem z głową z ogonem:
            reszta to tłumacz ogon przez mapę
            znalezisko to szukaj głowy w mapie
            gdy znalezisko jest:
                Sukcesem z wartością:
                    zwróć dodaj wartość do reszty
                Błędem:
                    zwróć resztę


