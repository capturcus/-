# ---------- _morpho_for_tag ----------

# Rozbiera części tagu SGJP na (przypadki, liczba, rodzaje).
# Rekursja od końca + nadpisanie wartością z głowy = "pierwsze trafienie
# wygrywa" jak w pythonowej pętli z continue.
aby badać części:
    części są:
        PustąListą:
            zwróć Morfologia o przypadkach utwórz_pustą o liczbie (Błąd o opisie "brak liczby w tagu") o rodzajach utwórz_pustą
        Węzłem z głową z ogonem:
            morfologia to badaj ogon
            atomy to podziel głowę po "."
            trafione to filtruj atomy według wymień_przypadki
            trafione jest:
                Węzłem:
                    przypadki morfologii to trafione
                PustąListą:
                    liczby to filtruj atomy według wymień_liczby
                    możliwa_liczba to bierz_pierwszą z liczb
                    możliwa_liczba jest:
                        Sukcesem:
                            liczba morfologii to możliwa_liczba
                        Błędem:
                            przetłumaczone to tłumacz atomy przez wymień_mapę_rodzajów
                            przetłumaczone jest:
                                Węzłem:
                                    rodzaje morfologii to przetłumaczone
                                PustąListą:
                                    ignoruj atomy
            zwróć morfologię


# ---------- load() — wczytanie bazy ----------

# Jeden wiersz sgjp.tab -> Sukces z Analizą (albo Błąd dla za krótkich
# wierszy — `?` propaguje go z wybrać).
aby przetwarzać wiersz:
    części to podziel wiersz po "\t"
    napis to wybrałbyś zero z części?
    pole to wybrałbyś jeden z części?
    etykieta to wybrałbyś dwa z części?
    kwalifikator to wydobądź (wybierz cztery z części) z ""
    lemat to wydobądź (bierz_pierwszą z (podziel pole po ":")) z polem
    klasa to wydobądź (bierz_pierwszą z (podziel etykieta po ":")) z etykietą
    morfologia to badaj (podziel etykieta po ":")
    analiza to Analiza o napisie napis o klasie klasa o lemacie lemat o etykiecie etykieta o kwalifikatorze kwalifikator o przypadkach przypadki morfologii o liczbie liczba morfologii o rodzajach rodzaje morfologii
    zwróć Sukces o wartości analiza

# db.setdefault(form, []).append(analiza) na assoc-liście.
aby dopisać analizę w słowniku:
    dotychczasowe to szukaj napisu analizy w słowniku
    dotychczasowe jest:
        Sukcesem z wartością:
            zwróć wstaw napis analizy z (dodaj analizę do wartości) do słownika
        Błędem:
            zwróć wstaw napis analizy z (dodaj analizę do utwórz_pustą) do słownika

aby wczytywać wiersze:
    wiersze są:
        PustąListą:
            zwróć Baza o formach utwórz_pustą o przyimkach utwórz_pustą
        Węzłem z głową z ogonem:
            baza to wczytuj ogon
            możliwa_analiza to przetwarzaj głowę
            możliwa_analiza jest:
                Błędem:
                    ignoruj możliwą_analizę
                Sukcesem z wartością:
                    formy bazy to dopisz wartość w formach bazy
                    jeśli klasa wartości równe "prep":
                        przyimki bazy to wstaw lemat wartości z (przypadki wartości) do przyimków bazy
            zwróć bazę


# ---------- analyze() ----------

aby analizować słowa w słowniku:
    słowa są:
        PustąListą:
            zwróć słowa
        Węzłem z głową z ogonem:
            reszta to analizuj ogon w słowniku
            znalezisko to szukaj głowy w słowniku
            analizy to wydobądź znalezisko z utwórz_pustą
            zwróć dodaj (OpisaneSłowo o słowie głowa o analizach analizy) do reszty


# ---------- canonical() ----------

# Analizy o klasie przymiotnikowej (adj/pact/ppas).
aby przesiewać analizy według klas:
    analizy są:
        PustąListą:
            zwróć analizy
        Węzłem z głową z ogonem:
            reszta to przesiewaj ogon według klas
            jeśli należy klasa głowy do klas:
                zwróć dodaj głowę do reszty
            zwróć resztę

# Pula kanonizacji: analizy przymiotnikowe, a gdy ich brak — wszystkie.
aby wybrać_pulę z analiz:
    przymiotnikowe to przesiewaj analizy według wymień_klasy_przymiotnikowe
    przymiotnikowe jest:
        PustąListą:
            zwróć analizy
        Węzłem:
            zwróć przymiotnikowe

# Pierwsza analiza, której lemat równa się słowu (citation match).
aby wyszukiwać słowo w analizach:
    analizy są:
        PustąListą:
            zwróć Błąd o opisie "żaden lemat nie pasuje"
        Węzłem z głową z ogonem:
            jeśli lemat głowy równe słowo:
                zwróć Sukces o wartości głowa
            zwróć wyszukuj słowo w ogonie

aby kanonizować słowo w słowniku:
    znalezisko to szukaj słowa w słowniku
    znalezisko jest:
        Błędem:
            zwróć słowo
        Sukcesem z wartością:
            pula to wybierz_pulę z wartości
            dopasowanie to wyszukuj słowo w puli
            dopasowanie jest:
                Sukcesem z wartością:
                    zwróć lemat wartości
                Błędem:
                    awaryjne to bierz_pierwszą z puli
                    awaryjne jest:
                        Sukcesem z wartością:
                            zwróć lemat wartości
                        Błędem:
                            zwróć słowo


