# ---------- _morpho_for_tag ----------

# Rozbiera części tagu SGJP na (przypadki, liczba, rodzaje).
# Rekursja od końca + nadpisanie wartością z głowy = "pierwsze trafienie
# wygrywa" jak w pythonowej pętli z continue.
aby badać części:
    gdy części są:
        Niczym:
            zwróć Morfologia o przypadkach Nic o liczbie (Błąd o opisie "brak liczby w tagu") o rodzajach Nic
        Ogniwem z głową z ogonem:
            morfologia to badaj ogon
            atomy to podziel_tekst głowę po '.'
            trafione to filtruj atomy według wyniku wymienienia_przypadków
            gdy trafione jest:
                Ogniwem:
                    przypadki morfologii to trafione
                Niczym:
                    liczby to filtruj atomy według wyniku wymienienia_liczb
                    możliwa_liczba to bierz_pierwszą z liczb
                    gdy możliwa_liczba jest:
                        Sukcesem:
                            liczba morfologii to możliwa_liczba
                        Błędem:
                            przetłumaczone to tłumacz atomy przez wynik wymienienia_mapy_rodzajów
                            gdy przetłumaczone jest:
                                Ogniwem:
                                    rodzaje morfologii to przetłumaczone
                                Niczym:
                                    ignoruj atomy
            zwróć morfologię


# ---------- load() — wczytanie bazy ----------

# Jeden wiersz sgjp.tab -> Sukces z Analizą (albo Błąd dla za krótkich
# wierszy — `?` propaguje go z wybrać).
aby przetwarzać wiersz:
    części to podziel_tekst wiersz po '\t'
    napis to wybrałbyś zero z części?
    pole to wybrałbyś jeden z części?
    etykieta to wybrałbyś dwa z części?
    kwalifikator to wydobądź wynik wybrania czterech z części z ""
    kawałki_pola to podziel_tekst pole po ':'
    lemat to wydobądź wynik brania_pierwszej z kawałków_pola z polem
    kawałki_etykiety to podziel_tekst etykietę po ':'
    klasa to wydobądź wynik brania_pierwszej z kawałków_etykiety z etykietą
    morfologia to badaj kawałki_etykiety
    analiza to Analiza o napisie napis o klasie klasa o lemacie lemat o etykiecie etykieta o kwalifikatorze kwalifikator o przypadkach przypadki morfologii o liczbie liczba morfologii o rodzajach rodzaje morfologii
    zwróć Sukces o wartości analiza

# db.setdefault(form, []).append(analiza) na assoc-liście.
aby dopisać analizę w słowniku:
    dotychczasowe to szukaj napisu analizy w słowniku
    gdy dotychczasowe jest:
        Sukcesem z wartością:
            zbiór to dodaj analizę do wartości
            zwróć wstaw napis analizy ze zbiorem do słownika
        Błędem:
            zalążek to Nic
            zbiór to dodaj analizę do zalążka
            zwróć wstaw napis analizy ze zbiorem do słownika

aby wczytywać wiersze:
    gdy wiersze są:
        Niczym:
            zwróć Baza o formach Nic o przyimkach Nic
        Ogniwem z głową z ogonem:
            baza to wczytuj ogon
            możliwa_analiza to przetwarzaj głowę
            gdy możliwa_analiza jest:
                Błędem:
                    ignoruj możliwą_analizę
                Sukcesem z wartością:
                    formy bazy to dopisz wartość w formach bazy
                    jeśli klasa wartości równe "prep":
                        przyimki bazy to wstaw lemat wartości z przypadkami wartości do przyimków bazy
            zwróć bazę


# ---------- analyze() ----------

aby analizować słowa w słowniku:
    gdy słowa są:
        Niczym:
            zwróć Nic
        Ogniwem z głową z ogonem:
            reszta to analizuj ogon w słowniku
            znalezisko to szukaj głowy w słowniku
            zalążek to Nic
            analizy to wydobądź znalezisko z zalążkiem
            zwróć dodaj (OpisaneSłowo o słowie głowa o analizach analizy) do reszty


# ---------- canonical() ----------

# Analizy o klasie przymiotnikowej (adj/pact/ppas); nazwa `odsiewać`,
# bo `przesiewać` (filtr po warunku funkcyjnym) zajmuje przygrywka.
aby odsiewać analizy według klas:
    gdy analizy są:
        Niczym:
            zwróć analizy
        Ogniwem z głową z ogonem:
            reszta to odsiewaj ogon według klas
            jeśli należy klasa głowy do klas:
                zwróć dodaj głowę do reszty
            zwróć resztę

# Pula kanonizacji: analizy przymiotnikowe, a gdy ich brak — wszystkie.
aby wybrać_pulę z analiz:
    przymiotnikowe to odsiewaj analizy według wyniku wymienienia_klas_przymiotnikowych
    gdy przymiotnikowe jest:
        Niczym:
            zwróć analizy
        Ogniwem:
            zwróć przymiotnikowe

# Pierwsza analiza, której lemat równa się słowu (citation match).
aby wyszukiwać słowo w analizach:
    gdy analizy są:
        Niczym:
            zwróć Błąd o opisie "żaden lemat nie pasuje"
        Ogniwem z głową z ogonem:
            jeśli lemat głowy równe słowo:
                zwróć Sukces o wartości głowa
            zwróć wyszukuj słowo w ogonie

aby kanonizować słowo w słowniku:
    znalezisko to szukaj słowa w słowniku
    gdy znalezisko jest:
        Błędem:
            zwróć słowo
        Sukcesem z wartością:
            pula to wybierz_pulę z wartości
            dopasowanie to wyszukuj słowo w puli
            gdy dopasowanie jest:
                Sukcesem z wartością:
                    zwróć lemat wartości
                Błędem:
                    awaryjne to bierz_pierwszą z puli
                    gdy awaryjne jest:
                        Sukcesem z wartością:
                            zwróć lemat wartości
                        Błędem:
                            zwróć słowo


# ---------- przykład użycia ----------

aby działać:
    wiersze to Nic
    wiersze to dodaj "kota\tkot\tsubst:sg:gen.acc:m2" do wierszy
    wiersze to dodaj "kot\tkot\tsubst:sg:nom:m2" do wierszy
    wiersze to dodaj "ładny\tładny\tadj:sg:nom:m1.m2.m3:pos" do wierszy
    wiersze to dodaj "dla\tdla\tprep:gen" do wierszy
    baza to wczytuj wiersze
    słowa to Nic
    słowa to dodaj "kota" do słów
    słowa to dodaj "ładny" do słów
    opisane to analizuj słowa w formach bazy
    liczba_opisanych to zmierz opisane
    wypisz liczbę_opisanych
    kanon to kanonizuj "kota" w formach bazy
    wypisz kanon
    morfologia to badaj wynik podzielenia_tekstu "subst:sg:gen.acc:m2" po ':'
    liczba_przypadków to zmierz przypadki morfologii
    wypisz liczbę_przypadków
    gdy liczba morfologii jest:
        Sukcesem z wartością:
            kanon to wartość
        Błędem z opisem:
            kanon to opis
    wypisz kanon
    znalezisko to szukaj "kota" w formach bazy
    liczba_analiz to zero
    gdy znalezisko jest:
        Sukcesem z wartością:
            liczba_analiz to zmierz wartość
        Błędem:
            ignoruj znalezisko
    wypisz liczbę_analiz
