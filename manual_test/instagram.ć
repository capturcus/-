# Backend aplikacji typu Instagram.
#
# Architektura:
# - kontenery własne: Lista (Węzeł albo PustaLista) — jak w analizatorze,
# - jedna unia Rezultat (Sukces albo Błąd) obsługuje i lookupy, i operacje
#   API; wywołania z obsługą błędu (tryb przypuszczający + `?`) propagują
#   Błąd z lookupów bez zagnieżdżonych dopasowań,
# - stan aplikacji mutowany zapisami do pól (chain-LHS), identyfikatory
#   nadaje licznik w stanie,
# - IO (sieć, dziennik, zegar, operacje tekstowe) zadeklarowane przez
#   `można` — sygnatury w całości jawne.

# ---------- kontenery ----------

definicja Węzła z elementem:
    głowa (element)
    ogon (Lista)

definicja PustejListy:
    znacznik (Liczba)

Lista to Węzeł albo PustaLista

definicja Sukcesu z elementem:
    wartość (element)

definicja Błędu:
    opis (Tekst)

Rezultat to Sukces albo Błąd

# ---------- model domeny ----------

definicja Użytkownika:
    identyfikator (Liczba)
    nazwa (Tekst)
    obserwowani (Lista o elemencie Liczba)

definicja Komentarza:
    autor (Liczba)
    tekst (Tekst)

definicja Postu:
    identyfikator (Liczba)
    autor (Liczba)
    treść (Tekst)
    chwila (Liczba)
    polubienia (Lista o elemencie Liczba)
    komentarze (Lista o elemencie Komentarz)

definicja Stanu:
    użytkownicy (Lista o elemencie Użytkownik)
    wpisy (Lista o elemencie Post)
    licznik (Liczba)

# ---------- świat zewnętrzny ----------

można wysłać_odpowiedź tekst (Tekst) do klienta (Liczba) -> Nic
można zapisać_dziennik wpis (Tekst) -> Nic
można powiadamiać odbiorcę (Liczba) o nowości (Tekst) -> Nic
można pobrać_czas -> Liczba
można skleić tekst (Tekst) z drugim (Tekst) -> Tekst
można zakodować liczbę (Liczba) -> Tekst

# ---------- operacje na listach ----------

aby utworzyć_pustą:
    zwróć PustaLista o znaczniku zero

aby dodać element do listy:
    zwróć Węzeł o głowie element o ogonie lista

aby liczyć listę:
    lista jest:
        PustąListą:
            zwróć zero
        Węzłem z ogonem:
            zwróć jeden plus licz ogon

aby należeć element do zbioru:
    zbiór jest:
        PustąListą:
            zwróć fałsz
        Węzłem z głową z ogonem:
            jeśli głowa równe element:
                zwróć prawda
            zwróć należy element do ogona

# Wyszukiwanie rekordu po identyfikatorze. Dzięki wymazywaniu parametrów
# unii ta sama funkcja obsługuje listę użytkowników i listę postów —
# wystarczy, że element ma pole `identyfikator`.
aby wyszukiwać numer w rekordach:
    rekordy są:
        PustąListą:
            zwróć Błąd o opisie "nie znaleziono rekordu"
        Węzłem z głową z ogonem:
            jeśli identyfikator głowy równe numer:
                zwróć Sukces o wartości głowa
            zwróć wyszukuj numer w ogonie

# ---------- operacje API (mutują stan, zwracają Rezultat) ----------

aby zarejestrować nazwę w stanie:
    użytkownik to Użytkownik o identyfikatorze licznik stanu o nazwie nazwa o obserwowanych utwórz_pustą
    użytkownicy stanu to dodaj użytkownika do użytkowników stanu
    licznik stanu to licznik stanu plus jeden
    zapisz_dziennik (sklej "nowe konto: " z nazwą)
    zwróć Sukces o wartości "zarejestrowano"

aby opublikować treść przez autora w stanie:
    twórca to wyszukiwałbyś autora w użytkownikach stanu?
    post to Post o identyfikatorze licznik stanu o autorze autor o treści treść o chwili pobierz_czas o polubieniach utwórz_pustą o komentarzach utwórz_pustą
    wpisy stanu to dodaj post do wpisów stanu
    licznik stanu to licznik stanu plus jeden
    zwróć Sukces o wartości "opublikowano"

aby polubić wpis przez fana w stanie:
    rekord to wyszukiwałbyś wpis we wpisach stanu?
    jeśli należy fan do polubień rekordu:
        zwróć Błąd o opisie "już polubiono"
    polubienia rekordu to dodaj fana do polubień rekordu
    powiadamiaj autora rekordu o "ktoś polubił twój post"
    zwróć Sukces o wartości "polubiono"

aby skomentować wpis przez autora słowami w stanie:
    rekord to wyszukiwałbyś wpis we wpisach stanu?
    komentarz to Komentarz o autorze autor o tekście słowa
    komentarze rekordu to dodaj komentarz do komentarzy rekordu
    zwróć Sukces o wartości "skomentowano"

aby obserwować cel przez fana w stanie:
    obserwujący to wyszukiwałbyś fana w użytkownikach stanu?
    rekord to wyszukiwałbyś cel w użytkownikach stanu?
    jeśli należy identyfikator rekordu do obserwowanych obserwującego:
        zwróć Błąd o opisie "już obserwuje"
    obserwowani obserwującego to dodaj identyfikator rekordu do obserwowanych obserwującego
    zwróć Sukces o wartości "zaobserwowano"

# ---------- oś czasu ----------

aby zbierać posty dla obserwowanych:
    posty są:
        PustąListą:
            zwróć posty
        Węzłem z głową z ogonem:
            reszta to zbieraj ogon dla obserwowanych
            jeśli należy autor głowy do obserwowanych:
                zwróć dodaj głowę do reszty
            zwróć resztę

aby opisywać posty:
    posty są:
        PustąListą:
            zwróć ""
        Węzłem z głową z ogonem:
            zwróć sklej treść głowy z (opisuj ogon)

# ---------- obsługa odpowiedzi ----------

aby zgłaszać rezultat do klienta:
    rezultat jest:
        Sukcesem z wartością:
            wyślij_odpowiedź wartość do klienta
        Błędem z opisem:
            zapisz_dziennik opis
            wyślij_odpowiedź opis do klienta

# ---------- przykładowa sesja ----------

aby działać:
    stan to Stan o użytkownikach utwórz_pustą o wpisach utwórz_pustą o liczniku jeden
    zgłaszaj (zarejestruj "ada" w stanie) do jeden
    zgłaszaj (zarejestruj "bob" w stanie) do dwa
    zgłaszaj (opublikuj "pierwszy post na osi" przez jeden w stanie) do jeden
    zgłaszaj (polub trzy przez dwa w stanie) do dwa
    zgłaszaj (skomentuj trzy przez dwa "ładne zdjęcie" w stanie) do dwa
    zgłaszaj (obserwuj jeden przez dwa w stanie) do dwa
    obserwator to wyszukuj dwa w użytkownikach stanu
    obserwator jest:
        Sukcesem z wartością:
            oś to zbieraj wpisy stanu dla obserwowanych wartości
            wyślij_odpowiedź (opisuj oś) do dwa
        Błędem z opisem:
            zapisz_dziennik opis
    wyślij_odpowiedź (sklej "liczba rekordów: " z (zakoduj licz wpisy stanu)) do jeden
