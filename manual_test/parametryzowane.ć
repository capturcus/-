# Typy parametryzowane — test parsera (typechecker czyta tylko głowy typów).

definicja Listy z elementem:
    wartość (element)
    następnik (Lista z elementem)

definicja Mapy z klucza na wartość:
    klucz (klucz)
    wartość (wartość)

definicja Drzewa dla rzeczy:
    wartość (rzecz)
    lewy_syn (Drzewo dla rzeczy)
    prawy_syn (Drzewo dla rzeczy)

aby zbudować_mapę:
    moja_mapa (Mapa z klucza na wartość) to Mapa
    lista_map (Lista z (Mapa z klucza na wartość)) to Lista
    zwróć moja_mapa

aby dodać do szeregu (Lista z elementem) element:
    nowy_węzeł to Lista
    zwróć nowy_węzeł


# --- Drzewo AVL (samobalansujące BST), parametryzowane elementem ---
# Puste poddrzewo to `Nic`; `Gałąź` grupuje węzeł i pustkę. Chainy na
# podmiocie dopasowania działają dzięki zawężeniu w gałęzi (smart cast),
# a przepływ węzła do slotu unijnego nie wymazuje mu typu (subsumpcja).
# Wstawianie utrzymuje wysokości (`odśwież`) i równowagę (`zbalansuj`).

definicja DrzewaZbalansowanego z elementem:
    wartość (element)
    wysokość (Liczba)
    lewy_syn (Gałąź)
    prawy_syn (Gałąź)

Gałąź to DrzewoZbalansowane albo Nic

aby zmierzyć gałąź:
    gałąź jest:
        DrzewemZbalansowanym z wysokością:
            zwróć wysokość
        Niczym:
            zwróć zero

aby wychylić gałąź:
    gałąź jest:
        DrzewemZbalansowanym z lewym_synem z prawym_synem:
            zwróć zmierz lewy_syn minus zmierz prawy_syn
        Niczym:
            zwróć zero

aby utworzyć_liść dla elementu:
    zwróć DrzewoZbalansowane o wartości element o wysokości jeden o lewym_synu Nic o prawym_synu Nic

aby odświeżyć drzewo:
    lewica to zmierz lewego_syna drzewa
    prawica to zmierz prawego_syna drzewa
    jeśli lewica większe od prawicy:
        wysokość drzewa to lewica plus jeden
    inaczej:
        wysokość drzewa to prawica plus jeden

aby obrócić_prawo drzewo:
    filar to lewy_syn drzewa
    filar jest:
        DrzewemZbalansowanym z prawym_synem:
            lewy_syn drzewa to prawy_syn
            prawy_syn filara to drzewo
            odśwież drzewo
            odśwież filar
            zwróć filar
        Niczym:
            zwróć drzewo

aby obrócić_lewo drzewo:
    filar to prawy_syn drzewa
    filar jest:
        DrzewemZbalansowanym z lewym_synem:
            prawy_syn drzewa to lewy_syn
            lewy_syn filara to drzewo
            odśwież drzewo
            odśwież filar
            zwróć filar
        Niczym:
            zwróć drzewo

aby zbalansować drzewo (DrzewoZbalansowane z elementem) -> DrzewoZbalansowane z elementem:
    wychylenie to wychyl drzewo
    jeśli wychylenie większe od jeden:
        filar to lewy_syn drzewa
        filar jest:
            DrzewemZbalansowanym:
                jeśli (wychyl filar) mniejsze od zero:
                    lewy_syn drzewa to obróć_lewo filar
            Niczym:
                zwróć drzewo
        zwróć obróć_prawo drzewo
    jeśli wychylenie mniejsze od minus jeden:
        filar to prawy_syn drzewa
        filar jest:
            DrzewemZbalansowanym:
                jeśli (wychyl filar) większe od zero:
                    prawy_syn drzewa to obróć_prawo filar
            Niczym:
                zwróć drzewo
        zwróć obróć_lewo drzewo
    zwróć drzewo

aby wstawić element do gałęzi:
    gałąź jest:
        DrzewemZbalansowanym z wartością:
            jeśli element mniejsze od wartości:
                lewy_syn gałęzi to wstaw element do lewego_syna gałęzi
            inaczej:
                prawy_syn gałęzi to wstaw element do prawego_syna gałęzi
            odśwież gałąź
            zwróć zbalansuj gałąź
        Niczym:
            zwróć utwórz_liść dla elementu
