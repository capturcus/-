# Typy parametryzowane — test parsera (typechecker czyta tylko głowy typów).

definicja Listy z elementem:
    wartość (element)
    następnik (Lista z elementem)

definicja Mapy z klucza na wartość:
    klucz (klucz)
    wartość (wartość)

definicja Drzewa dla rzeczy:
    wartość (rzecz)
    lewy_syn (Drzewo dla rzeczy)
    prawy_syn (Drzewo dla rzeczy)

aby zbudować_mapę:
    moja_mapa (Mapa z klucza na wartość) to Mapa
    lista_map (Lista z (Mapa z klucza na wartość)) to Lista
    zwróć moja_mapa

aby dodać do szeregu (Lista z elementem) element:
    nowy_węzeł to Lista
    zwróć nowy_węzeł


# --- Drzewo AVL (samobalansujące BST), parametryzowane elementem ---
# Puste poddrzewo to węzeł-wartownik o wysokości zero (bez unii: chainy
# wymagają typu strukturalnego, a przepływ zmiennej do slotu unijnego
# rozszerzyłby jej typ i zepsuł chainy w fixpoincie). Wstawianie utrzymuje
# wysokości (`odśwież`) i równowagę (`zbalansuj` — LL/LR/RR/RL).

definicja DrzewaZbalansowanego z elementem:
    wartość (element)
    wysokość (Liczba)
    lewy_syn (DrzewoZbalansowane z elementem)
    prawy_syn (DrzewoZbalansowane z elementem)

aby utworzyć_pustkę -> DrzewoZbalansowane z elementem:
    zwróć DrzewoZbalansowane o wysokości zero

aby utworzyć_liść dla elementu -> DrzewoZbalansowane z elementem:
    zwróć DrzewoZbalansowane o wartości element o wysokości jeden o lewym_synu (utwórz_pustkę) o prawym_synu (utwórz_pustkę)

aby wychylić drzewo (DrzewoZbalansowane z elementem) -> Liczba:
    zwróć wysokość lewego_syna drzewa minus wysokość prawego_syna drzewa

aby odświeżyć drzewo (DrzewoZbalansowane z elementem):
    lewica to wysokość lewego_syna drzewa
    prawica to wysokość prawego_syna drzewa
    jeśli lewica większe od prawicy:
        wysokość drzewa to lewica plus jeden
    inaczej:
        wysokość drzewa to prawica plus jeden

aby obrócić_prawo drzewo (DrzewoZbalansowane z elementem) -> DrzewoZbalansowane z elementem:
    filar to lewy_syn drzewa
    lewy_syn drzewa to prawy_syn filara
    prawy_syn filara to drzewo
    odśwież drzewo
    odśwież filar
    zwróć filar

aby obrócić_lewo drzewo (DrzewoZbalansowane z elementem) -> DrzewoZbalansowane z elementem:
    filar to prawy_syn drzewa
    prawy_syn drzewa to lewy_syn filara
    lewy_syn filara to drzewo
    odśwież drzewo
    odśwież filar
    zwróć filar

aby zbalansować drzewo (DrzewoZbalansowane z elementem) -> DrzewoZbalansowane z elementem:
    wychylenie to wychyl drzewo
    jeśli wychylenie większe od jeden:
        jeśli (wychyl lewego_syna drzewa) mniejsze od zero:
            lewy_syn drzewa to obróć_lewo lewego_syna drzewa
        zwróć obróć_prawo drzewo
    jeśli wychylenie mniejsze od minus jeden:
        jeśli (wychyl prawego_syna drzewa) większe od zero:
            prawy_syn drzewa to obróć_prawo prawego_syna drzewa
        zwróć obróć_lewo drzewo
    zwróć drzewo

aby wstawić element do drzewa (DrzewoZbalansowane z elementem) -> DrzewoZbalansowane z elementem:
    jeśli wysokość drzewa równe zero:
        zwróć utwórz_liść dla elementu
    jeśli element mniejsze od wartości drzewa:
        lewy_syn drzewa to wstaw element do lewego_syna drzewa
    inaczej:
        prawy_syn drzewa to wstaw element do prawego_syna drzewa
    odśwież drzewo
    zwróć zbalansuj drzewo
