# ---------- dopasowanie argumentów do parametrów ----------
# (port type_parser.slot_matches + match_args_to_slots)

aby sprawdzić argument wobec parametru:
    jeśli przyimek argumentu nierówne przyimek parametru:
        zwróć fałsz
    jeśli policz (przypadki argumentu) równe zero:
        zwróć prawda
    jeśli policz (przypadki parametru) równe zero:
        zwróć prawda
    zwróć krzyżuj (przypadki argumentu) z (przypadki parametru)

# numery miejsc pasujących do jednego argumentu
aby wyliczyć_kandydatów dla argumentu wśród parametrów od numeru:
    parametry są:
        PustąListą:
            zwróć utwórz_pustą
        Węzłem z głową z ogonem:
            reszta to wylicz_kandydatów dla argumentu wśród ogona od (numer plus jeden)
            jeśli sprawdź argument wobec głowy:
                zwróć doczep numer do reszty
            zwróć resztę

# lista list kandydatów — po jednej na argument
aby zgromadzić_kandydatów dla argumentów wśród parametrów:
    argumenty są:
        PustąListą:
            zwróć utwórz_pustą
        Węzłem z głową z ogonem:
            zwróć doczep (wylicz_kandydatów dla głowy wśród parametrów od zero) do (zgromadź_kandydatów dla ogona wśród parametrów)

# odwrotne wyszukanie: numer argumentu przydzielonego danemu miejscu
aby odszukać miejsce w przydziałach:
    przydziały są:
        PustąListą:
            zwróć Błąd o opisie "miejsce bez przydzielonego argumentu"
        Węzłem z głową z ogonem:
            jeśli zawartość głowy równe miejsce:
                zwróć Sukces o wartości klucz głowy
            zwróć odszukaj miejsce w ogonie

# ułóż argumenty w kolejności miejsc sygnatury
aby ułożyć argumenty według przydziałów od numeru do krotności:
    jeśli numer większe równe krotność:
        zwróć Sukces o wartości utwórz_pustą
    indeks to odszukałbyś numer w przydziałach?
    argument to wybrałbyś indeks z argumentów?
    reszta to ułożyłbyś argumenty według przydziałów od (numer plus jeden) do krotności?
    zwróć Sukces o wartości (doczep argument do reszty)

aby dopasować argumenty do parametrów:
    krotność to policz parametry
    kandydaci to zgromadź_kandydatów dla argumentów wśród parametrów
    przydziały to utwórz_pustą
    obsada to utwórz_pustą
    # krok 1: do utraty postępu przydzielaj argumenty z dokładnie
    # jednym wolnym miejscem
    dopóki prawda:
        postęp to fałsz
        numer to zero
        dopóki numer mniejsze od krotności:
            los to szukaj numeru w przydziałach
            los jest:
                Sukcesem:
                    ignoruj los
                Błędem:
                    kandydatura to wydobądź (wybierz numer z kandydatów) z utwórz_pustą
                    pula to przesiej kandydaturę przez obsadę
                    jeśli policz pulę równe jeden:
                        miejsce to wydobądź (wybierz zero z puli) z zero
                        przydziały to wstaw numer z miejscem do przydziałów
                        obsada to doczep miejsce do obsady
                        postęp to prawda
            numer to numer plus jeden
        jeśli nie postęp:
            stop
    # krok 2: reszta pozycyjnie do wolnych miejsc, z kontrolą zgodności
    wolne_miejsca to przesiej (wylicz_ciąg od zero do krotności) przez obsadę
    numer to zero
    dopóki numer mniejsze od krotności:
        los to szukaj numeru w przydziałach
        los jest:
            Sukcesem:
                ignoruj los
            Błędem:
                wolne_miejsca są:
                    PustąListą:
                        zwróć Błąd o opisie "argument nie pasuje do żadnego wolnego parametru"
                    Węzłem z głową z ogonem:
                        kandydatura to wydobądź (wybierz numer z kandydatów) z utwórz_pustą
                        jeśli nie należy głowa do kandydatury:
                            zwróć Błąd o opisie "argument nie pasuje do parametru w trybie pozycyjnym"
                        przydziały to wstaw numer z głową do przydziałów
                        wolne_miejsca to ogon
        numer to numer plus jeden
    zwróć ułóż argumenty według przydziałów od zero do krotności

