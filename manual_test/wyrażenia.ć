# ---------- operacje na listach ----------

aby ignorować rzecz:
    zwróć

aby wyliczyć element:
    zwróć Ogniwo o głowie element o ogonie Nic

aby doczepić element do spisu:
    zwróć Ogniwo o głowie element o ogonie spis

aby należeć element do spisu:
    gdy spis jest:
        Niczym:
            zwróć fałsz
        Ogniwem z głową z ogonem:
            jeśli głowa równe element:
                zwróć prawda
            zwróć należy element do ogona

# elementy spisu NIEOBECNE w sicie
aby odsiać spis przez sito:
    gdy spis jest:
        Niczym:
            zwróć Nic
        Ogniwem z głową z ogonem:
            reszta to odsiej ogon przez sito
            jeśli należy głowa do sita:
                zwróć resztę
            zwróć doczep głowę do reszty

# część wspólna dwóch spisów
aby przecinać spis z drugim_spisem:
    gdy spis jest:
        Niczym:
            zwróć Nic
        Ogniwem z głową z ogonem:
            reszta to przecinaj ogon z drugim_spisem
            jeśli należy głowa do drugiego_spisu:
                zwróć doczep głowę do reszty
            zwróć resztę

# suma dwóch spisów bez powtórzeń
aby zjednoczyć spis z drugim_spisem:
    gdy spis jest:
        Niczym:
            zwróć drugi_spis
        Ogniwem z głową z ogonem:
            reszta to zjednocz ogon z drugim_spisem
            jeśli należy głowa do reszty:
                zwróć resztę
            zwróć doczep głowę do reszty

# czy każdy element spisu występuje w drugim
aby sprawdzać_pokrycie spisu przez drugi_spis:
    gdy spis jest:
        Niczym:
            zwróć prawda
        Ogniwem z głową z ogonem:
            jeśli nie należy głowa do drugiego_spisu:
                zwróć fałsz
            zwróć sprawdzaj_pokrycie ogona przez drugi_spis

# czy część wspólna dwóch spisów jest niepusta
aby krzyżować spis z drugim_spisem:
    gdy spis jest:
        Niczym:
            zwróć fałsz
        Ogniwem z głową z ogonem:
            jeśli należy głowa do drugiego_spisu:
                zwróć prawda
            zwróć krzyżuj ogon z drugim_spisem

# ciąg liczb od początku (włącznie) do kresu (wyłącznie)
aby rozpinać_ciąg od początku do kresu:
    jeśli początek większe równe kres:
        zwróć Nic
    następny_początek to początek plus jeden
    reszta to rozpinaj_ciąg od następnego_początku do kresu
    zwróć doczep początek do reszty

# sklejenie kawałków tekstu ze spoiwem między nimi
aby zszywać kawałki spoiwem:
    gdy kawałki są:
        Niczym:
            zwróć ""
        Ogniwem z głową z ogonem:
