# ---------- dyspozytor słowa ----------

aby rozpoznawać słowo przez parser od pozycji:
    następna_pozycja to pozycja plus jeden
    lematy to spisuj_lematy dla wariantów słowa
    # 1. słowo języka `wynik` — wywołanie przez gerundium z przypadkiem
    jeśli należy "wynik" do lematów:
        zwróć rozwikłaj_nominalizację przez parser od następnej_pozycji przy wyniku uzbierania_przypadków dla "wynik" w słowie
    # 2. słowo języka `literał` — nośnik przypadka dla literałów
    jeśli należy "literał" do lematów:
        zwróć ostempluj_wartość przez parser od następnej_pozycji przy wyniku uzbierania_przypadków dla "literał" w słowie
    # 3. konstrukcja struktury — lemat jest znanym typem; przypadek
    # konstrukcji nadaje odmieniona głowa
    poszlaka to wyśledź_typ dla wariantów słowa wśród typów otoczenia parsera
    gdy poszlaka jest:
        Sukcesem z wartością:
            zwróć rozbieraj_konstrukcję przez parser od następnej_pozycji o typie wartość przy wyniku uzbierania_przypadków dla wartości w słowie
        Błędem:
            ignoruj poszlakę
    # 4. łańcuch dopełniaczowy — pole, a za nim słowo w dopełniaczu
    jeśli krzyżuje lematy z polami otoczenia parsera i majaczy_dopełniacz w żetonach parsera na następnej_pozycji przy przyimkach otoczenia parsera:
        zwróć rozbieraj_łańcuch przez parser od następnej_pozycji za słowem
    # 5. wbudowana aplikacja i bejcowanie wartości funkcyjnych
    jeśli należy "zastosować" do lematów:
        ładunek to zbierałbyś_ładunek przez parser od następnej_pozycji?
        stan to Stan o drzewie Aplikacja o funkcji funkcja ładunku o dopełnieniach dopełnienia ładunku o przypadkach Nic o pozycji pozycja ładunku
        zwróć obsługuj stan według słowa przez parser
    jeśli należy "związać" do lematów:
        jeśli tryb słowa równe "przypuszczający":
            zwróć Błąd o opisie "'zwiąż' nie zawodzi — tryb przypuszczający nie dotyczy wiązania argumentów"
        ładunek to zbierałbyś_ładunek przez parser od następnej_pozycji?
        zwróć Sukces o wartości Stan o drzewie Bejca o funkcji funkcja ładunku o dopełnieniach dopełnienia ładunku o przypadkach Nic o pozycji pozycja ładunku
    # 6. wywołanie zdefiniowanej funkcji
    połów to namierzaj_sygnaturę dla lematów wśród sygnatur otoczenia parsera
    gdy połów jest:
        Sukcesem z wartością:
            stan to rozbierałbyś_wywołanie przez parser od następnej_pozycji według wartości przy fałsz?
            zwróć obsługuj stan według słowa przez parser
        Błędem:
            ignoruj połów
    # 7. odwołanie do zmiennej — zmienna przesłania referencję gerundialną
    wycinek to zawężaj warianty słowa w zakresie parsera
    jeśli zmierz wycinek większe od zera:
        zwróć Sukces o wartości Stan o drzewie Odwołanie o napisie napis słowa o wariantach wycinek o pozycji następna_pozycja
    # 8. referencja gerundialna do funkcji
    jeśli podstawa słowa nierówne "":
        ślad to wyszukaj_sygnaturę dla podstawy słowa wśród sygnatur otoczenia parsera
        gdy ślad jest:
            Sukcesem z wartością:
                zwróć Sukces o wartości Stan o drzewie Odsyłacz o celu nazwa wartości o przypadkach zsumuj_przypadki dla wariantów słowa o pozycji następna_pozycja
            Błędem:
                ignoruj ślad
    zwróć Błąd o opisie sklej "'" z wynikiem sklejenia napisu słowa z "' nie jest zadeklarowaną zmienną w tym miejscu"

