# Słownik (mapa klucz→wartość) na drzewie AVL: klucze to Teksty
# w porządku leksykograficznym (operacje_tekstowe.porównać), wartości
# generyczne. Wkładanie funkcyjne (nowe drzewo) z wyważaniem rotacjami;
# wzrost (wysokość) trzymany w konarze. Pusty słownik ≡ Nic.

uwzględnij przygrywka.ć
uwzględnij operacje_tekstowe.ć

definicja Konaru z owocem:
    klucz (Tekst)
    zapas (owoc)
    lewica (Słownik)
    prawica (Słownik)
    wzrost (Liczba)

Słownik to Konar albo Nic

aby zmierzyć_wzrost słownika (Słownik) -> Liczba:
    gdy słownik jest:
        Konarem ze wzrostem:
            zwróć wzrost
        Niczym:
            zwróć zero

# Przewaga lewej strony nad prawą (dodatnia → lewa wyższa).
aby wyznaczyć_przewagę słownika (Słownik) -> Liczba:
    gdy słownik jest:
        Konarem z lewicą z prawicą:
            zwróć zmierz_wzrost lewicy minus zmierz_wzrost prawicy
        Niczym:
            zwróć zero

aby wybrać_większe z pierwszej (Liczba) z drugiej (Liczba) -> Liczba:
    jeśli pierwsza mniejsze od druga:
        zwróć druga
    zwróć pierwsza

aby zbudować_konar z klucza (Tekst) z zapasu z lewicy (Słownik) z prawicy (Słownik) -> Słownik:
    wzrost_lewicy to zmierz_wzrost lewicy
    wzrost_prawicy to zmierz_wzrost prawicy
    zwróć Konar o kluczu klucz o zapasie zapas o lewicy lewica o prawicy prawica o wzroście jeden plus wybierz_większe z wzrostu_lewicy z wzrostu_prawicy

aby obrócić_w_prawo słownik (Słownik) -> Słownik:
    gdy słownik jest:
        Konarem jako korzeń:
            gdy lewica korzenia jest:
                Konarem jako oś:
                    prawy_konar to zbuduj_konar z klucza korzenia z zapasu korzenia z prawicy osi z prawicy korzenia
                    zwróć zbuduj_konar z klucza osi z zapasu osi z lewicy osi z prawego_konaru
                Niczym:
                    zwróć słownik
        Niczym:
            zwróć słownik

aby obrócić_w_lewo słownik (Słownik) -> Słownik:
    gdy słownik jest:
        Konarem jako korzeń:
            gdy prawica korzenia jest:
                Konarem jako oś:
                    lewy_konar to zbuduj_konar z klucza korzenia z zapasu korzenia z lewicy korzenia z lewicy osi
                    zwróć zbuduj_konar z klucza osi z zapasu osi z lewego_konaru z prawicy osi
                Niczym:
                    zwróć słownik
        Niczym:
            zwróć słownik

aby wyrównać słownik (Słownik) -> Słownik:
    przewaga to wyznacz_przewagę słownika
    jeśli przewaga większe od jeden:
        gdy słownik jest:
            Konarem jako korzeń:
                jeśli wyznacz_przewagę lewicy korzenia mniejsze od zero:
                    obrócona_lewica to obróć_w_lewo lewicę korzenia
                    zwróć obróć_w_prawo wynik zbudowania_konaru z klucza korzenia z zapasu korzenia z obróconej_lewicy z prawicy korzenia
                zwróć obróć_w_prawo słownik
            Niczym:
                zwróć słownik
    jeśli przewaga mniejsze od (minus jeden):
        gdy słownik jest:
            Konarem jako korzeń:
                jeśli wyznacz_przewagę prawicy korzenia większe od zero:
                    obrócona_prawica to obróć_w_prawo prawicę korzenia
                    zwróć obróć_w_lewo wynik zbudowania_konaru z klucza korzenia z zapasu korzenia z lewicy korzenia z obróconej_prawicy
                zwróć obróć_w_lewo słownik
            Niczym:
                zwróć słownik
    zwróć słownik

# Wkładanie: istniejący klucz nadpisuje wartość; nowy schodzi w gałąź
# wyznaczoną porządkiem leksykograficznym, a droga powrotna wyważa.
aby włożyć zapas pod kluczem (Tekst) do słownika (Słownik) -> Słownik:
    gdy słownik jest:
        Niczym:
            zwróć zbuduj_konar z klucza z zapasu z Nic z Nic
        Konarem jako korzeń:
            porządek to porównaj klucz z kluczem korzenia
            jeśli porządek równe zero:
                zwróć zbuduj_konar z klucza z zapasu z lewicy korzenia z prawicy korzenia
            jeśli porządek mniejsze od zero:
                nowa_lewica to włóż zapas pod kluczem do lewicy korzenia
                zwróć wyrównaj wynik zbudowania_konaru z klucza korzenia z zapasu korzenia z nowej_lewicy z prawicy korzenia
            nowa_prawica to włóż zapas pod kluczem do prawicy korzenia
            zwróć wyrównaj wynik zbudowania_konaru z klucza korzenia z zapasu korzenia z lewicy korzenia z nowej_prawicy

# Odczyt: Sukces z wartością albo Błąd, gdy klucza nie ma.
aby znaleźć klucz (Tekst) w słowniku (Słownik):
    gdy słownik jest:
        Niczym:
            zwróć Błąd o opisie "nie znaleziono"
        Konarem jako korzeń:
            porządek to porównaj klucz z kluczem korzenia
            jeśli porządek równe zero:
                zwróć Sukces o wartości zapas korzenia
            jeśli porządek mniejsze od zero:
                zwróć znajdź klucz w lewicy korzenia
            zwróć znajdź klucz w prawicy korzenia

# Liczba wpisów.
aby zliczyć_wpisy słownika (Słownik) -> Liczba:
    gdy słownik jest:
        Konarem z lewicą z prawicą:
            zwróć jeden plus zliczyć_wpisy lewicy plus zliczyć_wpisy prawicy
        Niczym:
            zwróć zero
