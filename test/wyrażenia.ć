# ---------- kontekst, zasięg, parser ----------

definicja Funkcji:
    lemat (Tekst)
    krotność (Liczba)

definicja Zasięgu:
    nazwy (Lista)
    rodzic (Otoczenie)

Otoczenie to Zasięg albo Nic

aby znać nazwę w otoczeniu:
    otoczenie jest:
        Niczym:
            zwróć fałsz
        Zasięgiem z nazwami z rodzicem:
            jeśli należy nazwa do nazw:
                zwróć prawda
            zwróć znaj nazwę w rodzicu

definicja Parsera:
    tokeny (Lista)
    pozycja (Liczba)
    funkcje (Lista)
    typy (Lista)
    pola (Lista)
    otoczenie (Otoczenie)

# ---------- kursor ----------

aby podglądać w parserze:
    zwróć wybierz pozycję parsera z tokenów parsera

aby przesuwać parser:
    pozycja parsera to pozycja parsera plus jeden

# Symbol pod kursorem albo "" (gdy koniec wejścia / inny rodzaj tokenu).
aby podpatrywać_symbol w parserze:
    spojrzenie to podglądaj w parserze
    spojrzenie jest:
        Błędem:
            zwróć ""
        Sukcesem z wartością:
            wartość jest:
                Symbolem z symbolem:
                    zwróć symbol
                Słowem:
                    zwróć ""
                Liczebnikiem:
                    zwróć ""
                Napisem:
                    zwróć ""

# Lemat słowa pod kursorem albo "".
aby podpatrywać_lemat w parserze:
    spojrzenie to podglądaj w parserze
    spojrzenie jest:
        Błędem:
            zwróć ""
        Sukcesem z wartością:
            wartość jest:
                Słowem z lematem:
                    zwróć lemat
                Symbolem:
                    zwróć ""
                Liczebnikiem:
                    zwróć ""
                Napisem:
                    zwróć ""

# Czy słowo pod kursorem ma dopełniacz (rozszerzenie łańcucha pól).
aby sprawdzać_dopełniacz w parserze:
    spojrzenie to podglądaj w parserze
    spojrzenie jest:
        Błędem:
            zwróć fałsz
        Sukcesem z wartością:
            wartość jest:
                Słowem z przypadkami:
                    zwróć należy "gen" do przypadków
                Symbolem:
                    zwróć fałsz
                Liczebnikiem:
                    zwróć fałsz
                Napisem:
                    zwróć fałsz

aby oczekiwać wzorca w parserze:
    znak to podpatruj_symbol w parserze
    jeśli znak równe wzorzec:
        przesuwaj parser
        zwróć Sukces o wartości znak
    zwróć Błąd o opisie (sklej "oczekiwano symbolu " z wzorcem)

# Lemat bieżącego słowa z konsumpcją tokenu.
aby czytać_lemat w parserze:
    spojrzenie to podglądałbyś w parserze?
    spojrzenie jest:
        Słowem z lematem:
            przesuwaj parser
            zwróć Sukces o wartości lemat
        Symbolem:
            zwróć Błąd o opisie "oczekiwano słowa"
        Liczebnikiem:
            zwróć Błąd o opisie "oczekiwano słowa"
        Napisem:
            zwróć Błąd o opisie "oczekiwano słowa"

aby odnajdywać_funkcję cel w spisie:
    spis jest:
        PustąListą:
            zwróć Błąd o opisie (sklej "nieznana funkcja " z celem)
        Węzłem z głową z ogonem:
            jeśli lemat głowy równe cel:
                zwróć Sukces o wartości głowa
            zwróć odnajduj_funkcję cel w ogonie

# ---------- gramatyka: lub < i < nie < porównanie < suma < iloczyn ----------

aby rozbierać_frazę w parserze:
    zwróć rozbieraj_alternatywę w parserze

aby rozbierać_alternatywę w parserze:
    pierwsza to rozbierałbyś_koniunkcję w parserze?
    zwróć doklejaj_alternatywę do pierwszej w parserze

aby doklejać_alternatywę do lewicy w parserze:
    jeśli podpatruj_lemat w parserze równe "lub":
        przesuwaj parser
        prawica to rozbierałbyś_koniunkcję w parserze?
        zwróć doklejaj_alternatywę do (Działanie o operatorze "lub" o lewicy lewica o prawicy prawica) w parserze
    zwróć Sukces o wartości lewica

aby rozbierać_koniunkcję w parserze:
    pierwsza to rozbierałbyś_negację w parserze?
    zwróć doklejaj_koniunkcję do pierwszej w parserze

aby doklejać_koniunkcję do lewicy w parserze:
    jeśli podpatruj_lemat w parserze równe "i":
        przesuwaj parser
        prawica to rozbierałbyś_negację w parserze?
        zwróć doklejaj_koniunkcję do (Działanie o operatorze "i" o lewicy lewica o prawicy prawica) w parserze
    zwróć Sukces o wartości lewica

aby rozbierać_negację w parserze:
    jeśli podpatruj_lemat w parserze równe "nie":
        przesuwaj parser
        środek to rozbierałbyś_negację w parserze?
        zwróć Sukces o wartości (Negacja o środku środek)
    zwróć rozbieraj_porównanie w parserze

aby rozbierać_porównanie w parserze:
    lewica to rozbierałbyś_sumę w parserze?
    znak to podpatruj_symbol w parserze
    jeśli znak równe "<" lub znak równe ">" lub znak równe "=":
        przesuwaj parser
        prawica to rozbierałbyś_sumę w parserze?
        zwróć Sukces o wartości (Działanie o operatorze znak o lewicy lewica o prawicy prawica)
    zwróć Sukces o wartości lewica

aby rozbierać_sumę w parserze:
    pierwsza to rozbierałbyś_iloczyn w parserze?
    zwróć doklejaj_sumę do pierwszej w parserze

aby doklejać_sumę do lewicy w parserze:
    znak to podpatruj_symbol w parserze
    jeśli znak równe "+" lub znak równe "-":
        przesuwaj parser
        prawica to rozbierałbyś_iloczyn w parserze?
        zwróć doklejaj_sumę do (Działanie o operatorze znak o lewicy lewica o prawicy prawica) w parserze
    zwróć Sukces o wartości lewica

aby rozbierać_iloczyn w parserze:
    pierwsza to rozbierałbyś_człon w parserze?
    zwróć doklejaj_iloczyn do pierwszej w parserze

aby doklejać_iloczyn do lewicy w parserze:
    jeśli podpatruj_symbol w parserze równe "*":
        przesuwaj parser
        prawica to rozbierałbyś_człon w parserze?
        zwróć doklejaj_iloczyn do (Działanie o operatorze "*" o lewicy lewica o prawicy prawica) w parserze
    zwróć Sukces o wartości lewica

# ---------- człony (primary) ----------

aby rozbierać_człon w parserze:
    spojrzenie to podglądałbyś w parserze?
    spojrzenie jest:
        Liczebnikiem z liczbą:
            przesuwaj parser
            zwróć Sukces o wartości (StałaLiczbowa o liczbie liczba)
        Napisem z treścią:
            przesuwaj parser
            zwróć Sukces o wartości (StałaTekstowa o tekście treść)
        Symbolem z symbolem:
            jeśli symbol równe "(":
                przesuwaj parser
                środek to rozbierałbyś_frazę w parserze?
                zamknięcie to oczekiwałbyś ")" w parserze?
                zwróć Sukces o wartości środek
            zwróć Błąd o opisie (sklej "nieoczekiwany symbol " z symbolem)
        Słowem:
            zwróć rozbieraj_słowo w parserze

# Dyspozycja słowa: budowa struktury (lemat jest typem), wywołanie
# (czasownik znanej funkcji, z trybem ochronnym), łańcuch pól (pole +
# dopełniacz dalej), odwołanie do zmiennej (sprawdzane w zasięgu).
aby rozbierać_słowo w parserze:
    spojrzenie to podglądałbyś w parserze?
    spojrzenie jest:
        Symbolem:
            zwróć Błąd o opisie "spodziewano słowa"
        Liczebnikiem:
            zwróć Błąd o opisie "spodziewano słowa"
        Napisem:
            zwróć Błąd o opisie "spodziewano słowa"
        Słowem z lematem z czasownikowym z przypuszczającym:
            przesuwaj parser
            jeśli należy lemat do typów parsera:
                zwróć rozbieraj_budowę lemat w parserze
            jeśli czasownikowe:
                zwróć rozbieraj_wywołanie lemat przypuszczające w parserze
            jeśli należy lemat do pól parsera i sprawdzaj_dopełniacz w parserze:
                zwróć rozbieraj_łańcuch lemat w parserze
            jeśli znaj lemat w otoczeniu parsera:
                zwróć Sukces o wartości (Odwołanie o celu lemat)
            zwróć Błąd o opisie (sklej lemat z " nie jest zadeklarowaną zmienną")

aby rozbierać_budowę typ w parserze:
    przypisy to zbierałbyś_przypisy w parserze?
    zwróć Sukces o wartości (Budowa o typie typ o wpisach przypisy)

aby zbierać_przypisy w parserze:
    jeśli podpatruj_lemat w parserze równe "o":
        przesuwaj parser
        pole to czytałbyś_lemat w parserze?
        wartość to rozbierałbyś_człon w parserze?
        reszta to zbierałbyś_przypisy w parserze?
        zwróć Sukces o wartości (dodaj (Przypis o polu pole o wartości wartość) do reszty)
    zwróć Sukces o wartości utwórz_pustą

aby rozbierać_wywołanie cel tryb w parserze:
    rekord to odnajdywałbyś_funkcję cel w funkcjach parsera?
    argumenty to zbierałbyś_argumenty (krotność rekordu) w parserze?
    jeśli tryb:
        zamknięcie to oczekiwałbyś "?" w parserze?
        zwróć Sukces o wartości (Wywołanie o celu cel o argumentach argumenty o ochronnym prawda)
    zwróć Sukces o wartości (Wywołanie o celu cel o argumentach argumenty o ochronnym fałsz)

aby zbierać_argumenty licznik w parserze:
    jeśli licznik równe zero:
        zwróć Sukces o wartości utwórz_pustą
    argument to rozbierałbyś_człon w parserze?
    reszta to zbierałbyś_argumenty (licznik minus jeden) w parserze?
    zwróć Sukces o wartości (dodaj argument do reszty)

aby rozbierać_łańcuch ogniwo w parserze:
    # uwaga: lista NIE może się nazywać "ogniwa" — "ogniwa" to też dopełniacz
    # lp od "ogniwo", więc skleiłaby się w zasięgu z parametrem "ogniwo"
    zbiór to dodaj ogniwo do utwórz_pustą
    dopóki sprawdzaj_dopełniacz w parserze i należy ogniwo do pól parsera:
        kolejne to czytałbyś_lemat w parserze?
        zbiór to dodaj kolejne do zbioru
        ogniwo to kolejne
    # ostatnie ogniwo to baza łańcucha — odczyt zmiennej, musi być w zasięgu
    jeśli nie znaj ogniwo w otoczeniu parsera:
        zwróć Błąd o opisie (sklej ogniwo z " nie jest zadeklarowaną zmienną")
    zwróć Sukces o wartości (Łańcuch o ogniwach (odwracaj zbiór na utwórz_pustą))

# ---------- opis drzewa (do raportowania) ----------

aby opisywać wyrażenie:
    wyrażenie jest:
        Odwołaniem z celem:
            zwróć cel
        StałąLiczbową z liczbą:
            zwróć zakoduj liczbę
        StałąTekstową z tekstem:
            zwróć sklej "\"" z (sklej tekst z "\"")
        Działaniem z operatorem z lewicą z prawicą:
            początek to sklej "(" z (opisuj lewicę)
            koniec to sklej (opisuj prawicę) z ")"
            zwróć sklej początek z (sklej operatora z końcem)
        Negacją ze środkiem:
            zwróć sklej "nie(" z (sklej (opisuj środek) z ")")
        Wywołaniem z celem z argumentami z ochronnym:
            nagłówek to sklej cel z "("
            jeśli ochronne:
                nagłówek to sklej "?" z nagłówkiem
            zwróć sklej nagłówek z (sklej (opisuj_listę argumenty) z ")")
        Łańcuchem z ogniwami:
            zwróć sklej "łańcuch(" z (sklej (sklejaj_lematy ogniwa) z ")")
        Budową z typem z wpisami:
            zwróć sklej "budowa:" z typem

aby opisywać_listę spisane:
    spisane jest:
        PustąListą:
            zwróć ""
        Węzłem z głową z ogonem:
            zwróć sklej (opisuj głowę) z (sklej " " z (opisuj_listę ogon))

aby sklejać_lematy ogniwa:
    ogniwa jest:
        PustąListą:
            zwróć ""
        Węzłem z głową z ogonem:
            zwróć sklej głowę z (sklej " " z (sklejaj_lematy ogon))

# ---------- fabryki tokenów (do sesji przykładowej) ----------

aby utworzyć_rzeczownik lemat spis:
    zwróć Słowo o lemacie lemat o przypadkach spis o czasownikowym fałsz o przypuszczającym fałsz

aby utworzyć_czasownik lemat tryb:
    zwróć Słowo o lemacie lemat o przypadkach utwórz_pustą o czasownikowym prawda o przypuszczającym tryb

aby utworzyć_symbol znak:
    zwróć Symbol o symbolu znak

# ---------- przykładowa sesja ----------

# Rozbiera odpowiednik frazy:
#   imię użytkownika + wybrałbyś zero z koszyka? * trzy
aby działać:
    mianownik to dodaj "nom" do utwórz_pustą
    dopełniacz to dodaj "gen" do utwórz_pustą
    tokeny to utwórz_pustą
    tokeny to dodaj (utwórz_rzeczownik "imię" mianownik) do tokenów
    tokeny to dodaj (utwórz_rzeczownik "użytkownik" dopełniacz) do tokenów
    tokeny to dodaj (utwórz_symbol "+") do tokenów
    tokeny to dodaj (utwórz_czasownik "wybrać" prawda) do tokenów
    tokeny to dodaj (Liczebnik o liczbie zero) do tokenów
    tokeny to dodaj (utwórz_symbol "?") do tokenów
    tokeny to dodaj (utwórz_symbol "*") do tokenów
    tokeny to dodaj (Liczebnik o liczbie trzy) do tokenów
    tokeny to odwracaj tokeny na utwórz_pustą

    zasięg to Zasięg o nazwach (dodaj "użytkownik" do utwórz_pustą) o rodzicu Nic
    spis_funkcji to dodaj (Funkcja o lemacie "wybrać" o krotności jeden) do utwórz_pustą
    parser to Parser o tokenach tokeny o pozycji zero o funkcjach spis_funkcji o typach utwórz_pustą o polach (dodaj "imię" do utwórz_pustą) o otoczeniu zasięg

    wynik to rozbieraj_frazę w parserze
    wynik jest:
        Sukcesem z wartością:
            wypisz (opisuj wartość)
        Błędem z opisem:
            wypisz opis
