# Analizator morfologiczny — przekład gćć-python/morph_anal.py na język Ć.
# Wbudowane typy `Lista` i `Mapa` muszą być widziane przez parser jako
# `definicja`, więc dostają tu jedno pole-zaślepkę. Listy/mapy tworzymy
# pustą formą `nowa Lista` / `nowa Mapa` i wypełniamy: dla map subscript-LHS
# (`mapa pod k to v`), dla list `dodać_do_listy lista element`.


# === Typy kontenerowe ===

definicja Listy:
    rozmiar (Liczba)


definicja Mapy:
    rozmiar (Liczba)


# === Typy domenowe ===

definicja Postaci:
    kategoria (Tekst)
    tryb (Tekst)
    aspekt (Tekst)
    liczebność (Tekst)
    osoba (Tekst)
    rodzaj (Tekst)


definicja Analizy:
    kategoria (Tekst)
    przypadki (Lista)
    lemat (Tekst)
    tag (Tekst)


definicja Wyniku:
    baza (Mapa)
    przyimki (Mapa)


# === Operacje wbudowane (zadeklarowane przez `można`) ===

# Listy
można dodać_do_listy l (Lista) e
można policzyć_długość_listy l (Lista) -> Liczba
można zawiera_lista l (Lista) e -> Przełącznik
można sumować_listy p (Lista) z d (Lista) -> Lista
można weź_ostatni_element l (Lista) -> Tekst

# Mapy
można ma_klucz m (Mapa) dla k
można weź_wartości_mapy m (Mapa) -> Lista

# Tekst
można podzielić_tekst t (Tekst) po s (Tekst) -> Lista
można weź_pierwszy_segment_tekstu t (Tekst) po s (Tekst) -> Tekst
można obciąć_białe_znaki_tekstu t (Tekst) -> Tekst
można policzyć_długość_tekstu t (Tekst) -> Liczba
można zawiera_tekst t (Tekst) e (Tekst) -> Przełącznik
można złącz_klucz_imiesłowu kat (Tekst) z lem (Tekst) -> Tekst

# Plik
można wczytać_plik s (Tekst) -> Lista

# Diagnostyka i czas
można wypisać_błąd komunikat
można zmierzyć_czas -> Liczba
można policzyć_różnicę_czasów od p (Liczba) do k (Liczba) -> Liczba

# Token (struktura tokenu z leksera — opaque z perspektywy tego pliku)
można czy_token_jest_słowem t -> Przełącznik
można weź_wartość_tokenu t -> Lista
można weź_analizy_tokenu t -> Lista
można stwórz_token_z_analizami t z a (Lista)


