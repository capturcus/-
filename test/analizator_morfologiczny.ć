# === Budowanie Postaci z tagu ===
# `kat` — kategoria (pos); `c` — lista części tagu po rozcięciu po ":".

aby zbudować_postać dla kat z c (Lista) -> Postać:
    tryb to tryb_dla_kategorii pod kat
    jeśli kat równe "inf" lub kat równe "imps" lub kat równe "pcon":
        zwrócić nowa Postać o kategorii kat o trybie tryb o aspekcie c pod jeden
    jeśli kat równe "impt" lub kat równe "fin" lub kat równe "bedzie" lub kat równe "fut":
        zwrócić nowa Postać o kategorii kat o trybie tryb o aspekcie c pod trzy o liczebności c pod jeden o osobie c pod dwa
    jeśli kat równe "praet" lub kat równe "winien":
        zwrócić nowa Postać o kategorii kat o trybie tryb o aspekcie c pod trzy o liczebności c pod jeden o rodzaju c pod dwa
    jeśli kat równe "cond":
        zwrócić nowa Postać o kategorii kat o trybie tryb o aspekcie c pod cztery o liczebności c pod jeden o rodzaju c pod dwa o osobie c pod trzy
    zwrócić


# Cache form czasownikowych — lazy lookup po surowym tagu.
aby weź_postać dla kat z t (Tekst) -> Postać:
    jeśli nie zawiera_lista czasowniki kat:
        zwrócić
    jeśli ma_klucz pamięć_postaci dla t:
        zwrócić pamięć_postaci pod t
    części to podzielić_tekst t po ":"
    wynik to zbudować_postać dla kat z części
    pamięć_postaci pod t to wynik
    zwrócić wynik


# === Wyciąganie przypadków z tagu ===
# `t` — surowy tag, `c` — części tagu, `p` — mapa cache po surowym tagu.

aby wyciągnąć_przypadki z t (Tekst) z c (Lista) z p (Mapa) -> Lista:
    jeśli ma_klucz p dla t:
        zwrócić p pod t
    znalezione to nowa Lista
    indeks to jeden
    dopóki indeks mniejsze od policzyć_długość_listy c:
        kandydat to c pod indeksem
        kandydaci to podzielić_tekst kandydat po "."
        i to zero
        dopóki i mniejsze od policzyć_długość_listy kandydaci:
            wybór to kandydaci pod i
            jeśli zawiera_lista przypadki wybór:
                dodać_do_listy znalezione wybór
            i to i plus jeden
        jeśli policzyć_długość_listy znalezione większe od zero:
            stop
        indeks to indeks plus jeden
    p pod t to znalezione
    zwrócić znalezione


# === Pomocnicze sprawdzenie kwalifikatorów ===
# Python: lista kwalifikatorów wykluczonych, podana w stringu — sprawdzamy
# substring w polu `qualifiers` SGJP. Tu prosty stub po wzorcu.

aby sprawdź_kwalifikator_wykluczony kw (Tekst) -> Przełącznik:
    zwrócić zawiera_tekst kw "nieoficjalny"


# === Załadowanie bazy SGJP ===

aby załadować z s (Tekst) -> Wynik:
    wypisać_błąd "Wczytywanie bazy"
    początek to zmierzyć_czas
    baza to nowa Mapa
    przyimki to nowa Mapa
    pamięć to nowa Mapa
    cytaty to nowa Mapa
    linie to wczytać_plik s

    dla linia w liniach:
        oczyszczona to obciąć_białe_znaki_tekstu linia
        kolumny to podzielić_tekst oczyszczona po "\t"
        jeśli policzyć_długość_listy kolumny mniejsze od trzy:
            dalej

        słowo to kolumny pod zero
        pole_lematu to kolumny pod jeden
        tag to kolumny pod dwa
        kwalifikatory to kolumny pod cztery
        lemat to weź_pierwszy_segment_tekstu pole_lematu po ":"
        kategoria to weź_pierwszy_segment_tekstu tag po ":"
        części to podzielić_tekst tag po ":"
        zbiór_przypadków to wyciągnąć_przypadki z tag z części z pamięć

        analiza to nowa Analiza o kategorii kategoria o przypadkach zbiór_przypadków o lemacie lemat o tagu tag

        jeśli nie ma_klucz baza dla słowo:
            baza pod słowo to nowa Lista
        dodać_do_listy (baza pod słowo) analiza

        jeśli kategoria równe "prep" i policzyć_długość_listy zbiór_przypadków większe od zero:
            jeśli nie sprawdź_kwalifikator_wykluczony kwalifikatory:
                jeśli nie ma_klucz przyimki dla lemat:
                    przyimki pod lemat to nowa Lista
                przyimki pod lemat to sumować_listy (przyimki pod lemat) z zbiór_przypadków

        jeśli zawiera_lista imiesłowy kategoria:
            jeśli policzyć_długość_listy części większe równe cztery:
                jeśli (części pod jeden) równe "sg" i zawiera_tekst (części pod dwa) "nom" i zawiera_tekst (części pod trzy) "m1" i (weź_ostatni_element części) równe "aff":
                    klucz to złącz_klucz_imiesłowu kategoria z lemat
                    cytaty pod klucz to słowo

    # Drugi przebieg: imiesłowy mają lemat zastąpiony cytowaną formą.
    wartości to weź_wartości_mapy baza
    dla lista_analiz w wartości:
        i to zero
        dopóki i mniejsze od policzyć_długość_listy lista_analiz:
            analiza to lista_analiz pod i
            jeśli zawiera_lista imiesłowy kategoria analizy:
                klucz to złącz_klucz_imiesłowu (kategoria analizy) z (lemat analizy)
                jeśli ma_klucz cytaty dla klucz:
                    nowy_lemat to cytaty pod klucz
                    lista_analiz pod i to nowa Analiza o kategorii (kategoria analizy) o przypadkach (przypadki analizy) o lemacie nowy_lemat o tagu (tag analizy)
            i to i plus jeden

    koniec to zmierzyć_czas
    wypisać_błąd policzyć_różnicę_czasów od początek do koniec
    zwrócić nowy Wynik o bazie baza o przyimkach przyimki


# === Analiza tokenów wejściowych ===
# Dla każdego WORD-tokenu doczepiamy listę analiz po segmencie.

aby analizować z t (Lista) z b (Mapa) -> Lista:
    wynik to nowa Lista
    dla token w t:
        jeśli czy_token_jest_słowem token:
            segmenty to weź_wartość_tokenu token
            analizy to nowa Lista
            dla segment w segmenty:
                jeśli ma_klucz b dla segment:
                    dodać_do_listy analizy (b pod segment)
                inaczej:
                    dodać_do_listy analizy (nowa Lista)
            wzbogacony to stwórz_token_z_analizami token z analizy
            dodać_do_listy wynik wzbogacony
        inaczej:
            dodać_do_listy wynik token
    zwrócić wynik


# === Forma kanoniczna ===

aby przefiltrować_po_kategoriach lista_analiz (Lista) po kategorie (Lista) -> Lista:
    wynik to nowa Lista
    i to zero
    dopóki i mniejsze od policzyć_długość_listy lista_analiz:
        analiza to lista_analiz pod i
        jeśli zawiera_lista kategorie kategoria analizy:
            dodać_do_listy wynik analiza
        i to i plus jeden
    zwrócić wynik


aby znaleźć_analizę_o_lemacie x (Lista) z l (Tekst) -> Analiza:
    i to zero
    dopóki i mniejsze od policzyć_długość_listy x:
        analiza to x pod i
        jeśli lemat analizy równe l:
            zwrócić analiza
        i to i plus jeden
    zwrócić


aby wyznaczyć_kanoniczną postać t -> Lista:
    segmenty to weź_wartość_tokenu t
    analizy to weź_analizy_tokenu t
    wynik to nowa Lista
    i to zero
    dopóki i mniejsze od policzyć_długość_listy segmenty:
        segment to segmenty pod i
        anas to analizy pod i
        jeśli policzyć_długość_listy anas równe zero lub policzyć_długość_tekstu segment równe jeden:
            dodać_do_listy wynik segment
        inaczej:
            preferowane to przefiltrować_po_kategoriach anas po przymiotnikopodobne
            jeśli policzyć_długość_listy preferowane równe zero:
                preferowane to anas
            wybrana to znaleźć_analizę_o_lemacie preferowane z segment
            jeśli wybrana równe pusty:
                wybrana to preferowane pod zero
            dodać_do_listy wynik lemat wybranej
        i to i plus jeden
    zwrócić wynik
