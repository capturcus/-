# Analizator morfologiczny — przekład gćć-python/morph_anal.py na język Ć.
# Wczytuje słownik SGJP, dopina analizy do tokenów, zwraca kanoniczną krotkę
# lematów dla zadanego tokenu.


# === Funkcje wbudowane (do uzupełnienia przez przyszły runtime) ===

# Wejście-wyjście, czas.
można otwórz_plik x (Tekst) -> Lista
można wypisz_na_stderr x (Tekst)
można weź_obecny_czas -> Liczba

# Operacje tekstowe.
można rozdziel x (Tekst) z separatorem (Tekst) -> Lista
można weź_przed_separatorem x (Tekst) z separatorem (Tekst) -> Tekst
można obniż_litery x (Tekst) -> Tekst
można podnieś_pierwszą_literę x (Tekst) -> Tekst
można weź_pierwszy_znak x (Tekst) -> Tekst
można sklej_dwa x (Tekst) z drugim (Tekst) -> Tekst
można policz_długość_tekstu x (Tekst) -> Liczba
można sprawdź_wielką_literę x (Tekst) -> Przełącznik
można sprawdź_równość_tekstów x (Tekst) z drugim (Tekst) -> Przełącznik

# Operacje listowe.
można dopisz_na_koniec x (Lista) z elementem
można policz_długość_listy x (Lista) -> Liczba

# Operacje mapowe.
można ustaw_w_mapie x (Mapa) z kluczem z wartością
można sprawdź_klucz_mapy x (Mapa) z kluczem -> Przełącznik
można pobierz_lub_pustą_listę x (Mapa) z kluczem -> Lista
można pobierz_klucze_mapy x (Mapa) -> Lista

# Klasyfikacja oznaczeń SGJP.
można sprawdź_czy_przypadek x (Tekst) -> Przełącznik
można sprawdź_czy_imiesłów x (Tekst) -> Przełącznik
można sprawdź_czy_czasownik x (Tekst) -> Przełącznik
można sprawdź_czy_przymiotnikowate x (Tekst) -> Przełącznik

# Atrybuty tokenu — dostęp do struktury Token z lekser-a.
można stwórz_nowy_token z rodzajem (Tekst) z segmentami (Lista) z analizami (Lista) -> Wyraz

# Sygnalizowanie błędu.
można rzuć_błąd x (Tekst)


# === Definicje typów ===

definicja Analizy:
    część_mowy (Tekst)
    lemat (Tekst)
    znacznik (Tekst)
    przypadek (Lista)


definicja Wyrazu:
    rodzaj (Tekst)
    segmenty (Lista)
    analizy (Lista)


definicja Bazy:
    słownik_form (Mapa)
    słownik_przyimków (Mapa)


definicja Klucza:
    część_mowy (Tekst)
    lemat (Tekst)


# Stuby typów wbudowanych — w docelowej formie języka będą dostępne
# bez deklaracji. Pola są symboliczne; parser potrzebuje ich tylko po to,
# żeby `nowa Lista` / `nowa Mapa` traktować jak konstrukcję struct.

definicja Listy:
    rozmiar (Liczba)


definicja Mapy:
    rozmiar (Liczba)


# === Pomocnicze konstruktory ===

aby stwórz_pustą_listę -> Lista:
    zwróć nowa Lista


aby stwórz_pustą_mapę -> Mapa:
    zwróć nowa Mapa


# === Wydobycie przypadków z znacznika SGJP ===
# Tag SGJP ma postać "pos:cat1:cat2:..." — szukamy pierwszej części po pos
# zawierającej oznaczenia przypadków (rozdzielone kropką).

aby wydobądź_przypadki x (Tekst) -> Lista:
    części to rozdziel x z ":"
    indeks to jeden
    dopóki indeks mniejsze od policz_długość_listy części:
        kawałek to części pod indeks
        atomy to rozdziel kawałek z "."
        zebrane to stwórz_pustą_listę
        wewnętrzny to zero
        dopóki wewnętrzny mniejsze od policz_długość_listy atomy:
            atom to atomy pod wewnętrzny
            jeśli sprawdź_czy_przypadek atom:
                dopisz_na_koniec zebrane z atomem
            wewnętrzny to wewnętrzny plus jeden
        jeśli policz_długość_listy zebrane większe od zero:
            zwróć zebrane
        indeks to indeks plus jeden
    zwróć stwórz_pustą_listę


# === Wczytanie bazy SGJP ===
# Format pliku: linie z tab-rozdzielonymi polami:
#   forma  lemat_z_kropką  znacznik  ...
# Budujemy mapę forma → lista Analiz oraz mapę przyimek → lista przypadków.
# Imiesłowy (pact, ppas) mają w SGJP lemmę = bezokolicznik; podmieniamy ją
# na formę cytowaną (nom sg m1).

aby ładuj_bazę x (Tekst) -> Bazy:
    wypisz_na_stderr "Wczytywanie bazy SGJP..."
    czas_startu to weź_obecny_czas
    mapa_form to stwórz_pustą_mapę
    mapa_przyimków to stwórz_pustą_mapę
    mapa_cytatów to stwórz_pustą_mapę
    wiersze to otwórz_plik x
    indeks_wiersza to zero
    dopóki indeks_wiersza mniejsze od policz_długość_listy wiersze:
        wiersz to wiersze pod indeks_wiersza
        kolumny to rozdziel wiersz z "	"
        jeśli policz_długość_listy kolumny mniejsze od trzy:
            indeks_wiersza to indeks_wiersza plus jeden
            dalej
        forma to kolumny pod zero
        pole_lematu to kolumny pod jeden
        znacznik to kolumny pod dwa
        lemat to weź_przed_separatorem pole_lematu z ":"
        część_mowy to weź_przed_separatorem znacznik z ":"
        przypadek to wydobądź_przypadki znacznik
        nowa_analiza to nowa Analiza o części_mowy część_mowy o lemacie lemat o znaczniku znacznik o przypadku przypadek
        jeśli nie sprawdź_klucz_mapy mapa_form z formą:
            ustaw_w_mapie mapa_form z formą z stwórz_pustą_listę
        kontener_analiz to mapa_form pod forma
        dopisz_na_koniec kontener_analiz z nową_analizą
        jeśli sprawdź_równość_tekstów część_mowy z "prep":
            jeśli policz_długość_listy przypadek większe od zero:
                jeśli nie sprawdź_klucz_mapy mapa_przyimków z lematem:
                    ustaw_w_mapie mapa_przyimków z lematem z stwórz_pustą_listę
                kontener_przypadków to mapa_przyimków pod lemat
                dla pojedynczy_przypadek w przypadek:
                    dopisz_na_koniec kontener_przypadków z pojedynczym_przypadkiem
        jeśli sprawdź_czy_imiesłów część_mowy:
            klucz_cytatu to nowy Klucz o części_mowy część_mowy o lemacie lemat
            ustaw_w_mapie mapa_cytatów z kluczem_cytatu z formą
        indeks_wiersza to indeks_wiersza plus jeden
    # Drugi przebieg — podmiana lematu imiesłowów na formę cytowaną.
    wszystkie_klucze to pobierz_klucze_mapy mapa_form
    indeks_klucza to zero
    dopóki indeks_klucza mniejsze od policz_długość_listy wszystkie_klucze:
        bieżący_klucz to wszystkie_klucze pod indeks_klucza
        pula_analiz to mapa_form pod bieżący_klucz
        dla pojedyncza_analiza w pula_analiz:
            jeśli sprawdź_czy_imiesłów część_mowy pojedynczej_analizy:
                stary_klucz to nowy Klucz o części_mowy część_mowy pojedynczej_analizy o lemacie lemat pojedynczej_analizy
                jeśli sprawdź_klucz_mapy mapa_cytatów z starym_kluczem:
                    nowy_lemat to mapa_cytatów pod stary_klucz
                    lemat pojedynczej_analizy to nowy_lemat
        indeks_klucza to indeks_klucza plus jeden
    wypisz_na_stderr "Baza wczytana."
    zwróć nowa Baza o słowniku_form mapa_form o słowniku_przyimków mapa_przyimków


# === Anotowanie tokenów analizami ===
# Dla każdego tokenu typu WORD dopinamy listę analiz per segment.
# Pozostałe tokeny przechodzą bez analiz.

aby przeanalizować_tokeny x (Lista) z bazą (Bazy) -> Lista:
    wynik to stwórz_pustą_listę
    dla wyraz w x:
        rodzaj_wyrazu to rodzaj wyrazu
        lista_segmentów to segmenty wyrazu
        analizy_per_segment to stwórz_pustą_listę
        jeśli sprawdź_równość_tekstów rodzaj_wyrazu z "WORD":
            dla segment w lista_segmentów:
                małe to obniż_litery segment
                pula to pobierz_lub_pustą_listę słownik_form bazy z małym
                dopisz_na_koniec analizy_per_segment z pulą
        nowy to stwórz_nowy_token z rodzajem_wyrazu z listą_segmentów z analizami_per_segment
        dopisz_na_koniec wynik z nowym
    zwróć wynik


# === Skapitalizowanie lematu ===
# Jeśli pierwszy znak segmentu jest wielki, podnieś pierwszy znak lematu.

aby skapitalizuj_lemat x (Tekst) z segmentem (Tekst) -> Tekst:
    jeśli policz_długość_tekstu segmentem równe zero:
        zwróć x
    jeśli policz_długość_tekstu x równe zero:
        zwróć x
    pierwszy to weź_pierwszy_znak segmentem
    jeśli nie sprawdź_wielką_literę pierwszy:
        zwróć x
    zwróć podnieś_pierwszą_literę x


# === Kanonikalizacja łagodna ===
# Per-segment: preferuj analizy adj-like, dopasuj do formy powierzchniowej,
# w razie braku — pierwszy element puli. Segmenty bez analiz / jednoznakowe
# przechodzą bez zmian.

aby znormalizuj_łagodnie wyraz (Wyraz) -> Lista:
    lista_segmentów to segmenty wyrazu
    zbiory_pul to analizy wyrazu
    wynik to stwórz_pustą_listę
    indeks to zero
    dopóki indeks mniejsze od policz_długość_listy lista_segmentów:
        segment to lista_segmentów pod indeks
        pula_segmentu to zbiory_pul pod indeks
        jeśli policz_długość_listy pula_segmentu równe zero:
            dopisz_na_koniec wynik z segmentem
            indeks to indeks plus jeden
            dalej
        jeśli policz_długość_tekstu segment równe jeden:
            dopisz_na_koniec wynik z segmentem
            indeks to indeks plus jeden
            dalej
        preferowane to stwórz_pustą_listę
        dla pojedyncza w pula_segmentu:
            jeśli sprawdź_czy_przymiotnikowate część_mowy pojedynczej:
                dopisz_na_koniec preferowane z pojedynczą
        jeśli policz_długość_listy preferowane równe zero:
            preferowane to pula_segmentu
        małe to obniż_litery segment
        wybrana to preferowane pod zero
        dla kandydatka w preferowane:
            jeśli sprawdź_równość_tekstów lemat kandydatki z małym:
                wybrana to kandydatka
        skapitalizowany to skapitalizuj_lemat lemat wybranej z segmentem
        dopisz_na_koniec wynik z skapitalizowanym
        indeks to indeks plus jeden
    zwróć wynik


# === Kanonikalizacja ścisła ===
# Per-segment filtruj analizy po wymaganym przypadku.
# Każdy segment z analizami musi mieć ≥1 takich, wszystkie z tą samą lematą,
# inaczej rzucamy błąd. Segmenty bez analiz / jednoznakowe — bez zmian.

aby znormalizuj_ściśle wyraz (Wyraz) z wymaganym_przypadkiem (Tekst) -> Lista:
    lista_segmentów to segmenty wyrazu
    zbiory_pul to analizy wyrazu
    wynik to stwórz_pustą_listę
    indeks to zero
    dopóki indeks mniejsze od policz_długość_listy lista_segmentów:
        segment to lista_segmentów pod indeks
        pula_segmentu to zbiory_pul pod indeks
        jeśli policz_długość_listy pula_segmentu równe zero:
            dopisz_na_koniec wynik z segmentem
            indeks to indeks plus jeden
            dalej
        jeśli policz_długość_tekstu segment równe jeden:
            dopisz_na_koniec wynik z segmentem
            indeks to indeks plus jeden
            dalej
        dopasowane to stwórz_pustą_listę
        dla pojedyncza w pula_segmentu:
            dla obecny_przypadek w przypadek pojedynczej:
                jeśli sprawdź_równość_tekstów obecny_przypadek z wymaganym_przypadkiem:
                    dopisz_na_koniec dopasowane z pojedynczą
        jeśli policz_długość_listy dopasowane równe zero:
            rzuć_błąd "segment nie ma wymaganej formy"
        unikalne_lematy to stwórz_pustą_mapę
        dla dopasowana w dopasowane:
            ustaw_w_mapie unikalne_lematy z lematem_dopasowanej z jeden
        klucze_lematów to pobierz_klucze_mapy unikalne_lematy
        jeśli policz_długość_listy klucze_lematów większe od jeden:
            rzuć_błąd "niejednoznaczność lematu"
        pierwsza to dopasowane pod zero
        skapitalizowany to skapitalizuj_lemat lemat pierwszej z segmentem
        dopisz_na_koniec wynik z skapitalizowanym
        indeks to indeks plus jeden
    zwróć wynik
