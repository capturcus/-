wykluczone_kwalifikatory to stwórz_listę_kwalifikatorów
tryb_dla_kategorii to stwórz_mapę_trybu


# === Budowanie Formy z tagu — POS w `k`, części tagu w `c` ===

aby zbuduj_formę dla k z c:
    tryb to tryb_dla_kategorii pod k
    n to policz_długość_listy c minus jeden
    jeśli k równe "inf" lub k równe "imps" lub k równe "pcon":
        zwrócić nowy Forma o kategorii k o trybie tryb
    jeśli k równe "fin" lub k równe "impt" lub k równe "bedzie" lub k równe "fut":
        zwrócić nowy Forma o kategorii k o trybie tryb o liczebności c pod jeden o osobie c pod dwa o aspekcie c pod trzy
    jeśli k równe "praet" lub k równe "winien":
        zwrócić nowy Forma o kategorii k o trybie tryb o liczebności c pod jeden o rodzaju c pod dwa o aspekcie c pod trzy
    jeśli k równe "cond":
        zwrócić nowy Forma o kategorii k o trybie tryb o liczebności c pod jeden o rodzaju c pod dwa o osobie c pod trzy o aspekcie c pod cztery
    zwrócić


# === Cache form czasownikowych — k=POS, t=tag, p=mapa pamięci ===

aby weź_formę dla k z t z p:
    jeśli nie zawiera_zbiór kategorie_czasownikowe k:
        zwrócić
    jeśli ma_klucz p dla t:
        zwrócić p pod t
    części to podziel_tekst t po ":"
    forma to zbuduj_formę dla k z części
    p pod t to forma
    zwrócić forma


# === Wyciąganie przypadków z tagu ===

aby wyciągnij_przypadki z t z c z p:
    jeśli ma_klucz p dla t:
        zwrócić p pod t
    znalezione to stworzyć_pusty_zbiór
    indeks to jeden
    dopóki indeks mniejsze od policz_długość_listy c:
        kandydat to c pod indeksem
        kandydaci to podziel_tekst kandydat po "."
        i to zero
        dopóki i mniejsze od policz_długość_listy kandydaci:
            wybór to kandydaci pod i
            jeśli zawiera_zbiór przypadki_dopuszczalne wybór:
                znalezione to połącz_zbiory znalezione z utwórz_jednoelementowy_zbiór z wybór
            i to i plus jeden
        jeśli policz_długość_zbioru znalezione większe od zero:
            stop
        indeks to indeks plus jeden
    p pod t to znalezione
    zwrócić znalezione


# === Załadowanie bazy SGJP ===

aby sprawdź_kwalifikator k:
    i to zero
    dopóki i mniejsze od policz_długość_listy wykluczone_kwalifikatory:
        kw to wykluczone_kwalifikatory pod i
        jeśli zawiera_tekst k kw:
            zwrócić prawda
        i to i plus jeden
    zwrócić fałsz


aby załaduj_bazę z s:
    wypisz_błąd "Wczytywanie bazy"
    początek to zmierz_aktualny_czas
    baza to stworzyć_pustą_mapę
    przyimki to stworzyć_pustą_mapę
    pamięć to stworzyć_pustą_mapę
    plik to otwórz_plik z s

    dopóki nie sprawdź_koniec_pliku plik:
        linia to czytaj_linię z plik
        linia to obetnij_białe_znaki linia
        kolumny to podziel_tekst linia po "\t"
        jeśli policz_długość_listy kolumny mniejsze od trzy:
            stop

        forma to kolumny pod zero
        pole_lematu to kolumny pod jeden
        tag to kolumny pod dwa
        kwalifikatory to kolumny pod cztery
        lemat to weź_pierwszy_segment pole_lematu po ":"
        kategoria to weź_pierwszy_segment tag po ":"
        części to podziel_tekst tag po ":"
        przypadki to wyciągnij_przypadki z tag z części z pamięć

        analiza to nowa Analiza z kategorią z przypadkami z lematem z tagiem

        jeśli nie ma_klucz baza dla forma:
            baza pod forma to stworzyć_pustą_listę
        dodaj_do_listy (baza pod forma) analiza

        jeśli kategoria równe "prep" i policz_długość_zbioru przypadki większe od zero:
            jeśli nie sprawdź_kwalifikator kwalifikatory:
                jeśli nie ma_klucz przyimki dla lemat:
                    przyimki pod lemat to stworzyć_pusty_zbiór
                przyimki pod lemat to połącz_zbiory (przyimki pod lemat) z przypadki

    zamknij_plik plik
    koniec to zmierz_aktualny_czas
    wypisz_błąd policz_różnicę_czasów od początek do koniec
    zwrócić nowy Wynik o bazie baza o przyimkach przyimki


# === Analiza tokenów wejściowych ===

aby weź_wartość_tokenu t:
    zwrócić

aby weź_rodzaj_tokenu t:
    zwrócić

aby czy_token_jest_słowem t:
    zwrócić

aby weź_analizy_tokenu t:
    zwrócić


aby analizuj t z b:
    wynik to stworzyć_pustą_listę
    i to zero
    dopóki i mniejsze od policz_długość_listy t:
        token to t pod i
        jeśli czy_token_jest_słowem token:
            segmenty to weź_wartość_tokenu token
            analizy to stworzyć_pustą_listę
            j to zero
            dopóki j mniejsze od policz_długość_listy segmenty:
                segment to segmenty pod j
                jeśli ma_klucz b dla segment:
                    dodaj_do_listy analizy (b pod segment)
                inaczej:
                    dodaj_do_listy analizy stworzyć_pustą_listę
                j to j plus jeden
            dodaj_do_listy wynik token
        inaczej:
            dodaj_do_listy wynik token
        i to i plus jeden
    zwrócić wynik


# === Forma kanoniczna ===

aby stwórz_listę_kategorii_przymiotnikopodobnych:
    zwrócić

aby przefiltruj_analizy_po_kategoriach x po y:
    zwrócić

aby znajdź_analizę_z_lematem x z l:
    i to zero
    dopóki i mniejsze od policz_długość_listy x:
        analiza to x pod i
        jeśli lemat analizy równe l:
            zwrócić analiza
        i to i plus jeden
    zwrócić

kategorie_przymiotnikopodobne to stworzyć_zbiór_z_listy stwórz_listę_kategorii_przymiotnikopodobnych


aby wyznacz_kanoniczną_formę t:
    segmenty to weź_wartość_tokenu t
    analizy to weź_analizy_tokenu t
    wynik to stworzyć_pustą_listę
    i to zero
    dopóki i mniejsze od policz_długość_listy segmenty:
        segment to segmenty pod i
        anas to analizy pod i
        jeśli policz_długość_listy anas równe zero lub policz_długość_tekstu segment równe jeden:
            dodaj_do_listy wynik segment
        inaczej:
            preferowane to przefiltruj_analizy_po_kategoriach anas po kategorie_przymiotnikopodobne
            jeśli policz_długość_listy preferowane równe zero:
                preferowane to anas
            wybrana to znajdź_analizę_z_lematem preferowane z segment
            jeśli wybrana równe pusty:
                wybrana to preferowane pod zero
            dodaj_do_listy wynik lemat wybranej
        i to i plus jeden
    zwrócić wynik
