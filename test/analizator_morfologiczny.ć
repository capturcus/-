# === Definicje typów danych ===

definicja Forma:
    kategoria (Tekst)
    tryb (Tekst)
    aspekt (Tekst)
    liczebność (Tekst)
    osoba (Tekst)
    rodzaj (Tekst)


definicja Analiza:
    kategoria (Tekst)
    przypadki (Zbiór)
    lemat (Tekst)
    tag (Tekst)


definicja Wynik:
    baza (Mapa)
    przyimki (Mapa)


