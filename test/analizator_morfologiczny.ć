# Przekład gćć-python/morph_anal.py na Ć.
#
# Brakujące elementy języka zastąpione konstrukcjami z typów
# parametryzowanych i wariantowych:
# - lista łączona:  Lista to Węzeł albo PustaLista  (zamiast list Pythona),
# - opcja:          Opcja to Trafienie albo Pudło   (zamiast None),
# - słownik:        lista Haseł (klucz, zawartość); wstawienie nowego Hasła
#   przesłania stare (semantyka assoc-listy zamiast dict.setdefault+update).
#
# Świadome uproszczenia względem pierwowzoru (wymagałyby stdlib):
# - podzielić to funkcja zewnętrzna (można) — dzielenie tekstu po separatorze
#   wymaga operacji na znakach, których język jeszcze nie ma,
# - kanonizować działa na pojedynczym słowie (segmentacja po "_" i wielkich
#   literach to znów operacje tekstowe),
# - pominięta poprawka lematów imiesłowów (cytaty) — wymaga kluczy złożonych,
# - pominięty skrót "czasownik nie ma morfologii" oraz scalanie przypadków
#   przyimków (wstawiamy nowsze hasło zamiast sumować zbiory).

definicja Węzła z elementem:
    głowa (element)
    ogon (Lista)

definicja PustejListy:
    znacznik (Liczba)

Lista to Węzeł albo PustaLista

definicja Trafienia z wartością:
    wartość (wartość)

definicja Pudła:
    powód (Tekst)

Opcja to Trafienie albo Pudło

definicja Hasła z klucza na zawartość:
    klucz (klucz)
    zawartość (zawartość)

# Odpowiednik MorphAnalysis (NamedTuple); "napis" to forma powierzchniowa,
# którą Python trzyma jako klucz w db — tu nosimy ją w analizie.
definicja Analizy:
    napis (Tekst)
    klasa (Tekst)
    lemat (Tekst)
    etykieta (Tekst)
    kwalifikator (Tekst)
    przypadki (Lista)
    liczba (Opcja)
    rodzaje (Lista)

# Wynik _morpho_for_tag: (case, number, gender).
definicja Morfologii:
    przypadki (Lista)
    liczba (Opcja)
    rodzaje (Lista)

# Odpowiednik pary (db, preps) zwracanej przez load().
definicja Bazy:
    formy (Lista)
    przyimki (Lista)

# Odpowiednik tokenu po analyze(): słowo + analizy z bazy.
definicja OpisanegoSłowa:
    słowo (Tekst)
    analizy (Lista)


# ---------- operacje na listach ----------

aby utworzyć_pustą:
    zwróć PustaLista o znaczniku zero

aby dodać element do listy:
    zwróć Węzeł o głowie element o ogonie lista

aby liczyć listę:
    lista jest:
        PustąListą:
            zwróć zero
        Węzłem z ogonem:
            zwróć jeden plus licz ogon

aby brać_pierwszą z listy:
    lista jest:
        PustąListą:
            zwróć Pudło o powodzie "lista jest pusta"
        Węzłem z głową:
            zwróć Trafienie o wartości głowa

aby wybrać pozycję z listy:
    lista jest:
        PustąListą:
            zwróć Pudło o powodzie "pozycja poza listą"
        Węzłem z głową z ogonem:
            jeśli pozycja równe zero:
                zwróć Trafienie o wartości głowa
            zwróć wybierz (pozycja minus jeden) z ogona

aby należeć element do zbioru:
    zbiór jest:
        PustąListą:
            zwróć zero równe jeden
        Węzłem z głową z ogonem:
            jeśli głowa równe element:
                zwróć zero równe zero
            zwróć należy element do ogona

# Przecięcie listy ze zbiorem (Python: frozenset(p for p in atoms if p in CASES)).
aby filtrować atomy według zbioru:
    atomy jest:
        PustąListą:
            zwróć atomy
        Węzłem z głową z ogonem:
            reszta to filtruj ogon według zbioru
            jeśli należy głowa do zbioru:
                zwróć dodaj głowę do reszty
            zwróć resztę

aby ignorować rzecz:
    zwróć


# ---------- opcja ----------

aby wydobyć opcję z awaryjną:
    opcja jest:
        Trafieniem z wartością:
            zwróć wartość
        Pudłem:
            zwróć awaryjną


# ---------- słownik (assoc-lista Haseł) ----------

aby szukać klucza w słowniku:
    słownik jest:
        PustąListą:
            zwróć Pudło o powodzie "nie znaleziono klucza"
        Węzłem z głową z ogonem:
            jeśli klucz głowy równe klucz:
                zwróć Trafienie o wartości zawartość głowy
            zwróć szukaj klucza w ogonie

aby wstawić klucz z zawartością do słownika:
    zwróć dodaj (Hasło o kluczu klucz o zawartości zawartość) do słownika

# Mapowanie atomów rodzaju przez GENDER_MAP — zbiera tylko trafienia.
aby tłumaczyć atomy przez mapę:
    atomy jest:
        PustąListą:
            zwróć atomy
        Węzłem z głową z ogonem:
            reszta to tłumacz ogon przez mapę
            znalezisko to szukaj głowy w mapie
            znalezisko jest:
                Trafieniem z wartością:
                    zwróć dodaj wartość do reszty
                Pudłem:
                    zwróć resztę


# ---------- stdlib tekstu (funkcja zewnętrzna) ----------

można podzielić tekst (Tekst) po separatorze (Tekst) -> Lista


