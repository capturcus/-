# Backend aplikacji typu Instagram.
#
# Architektura:
# - kontenery własne: Lista (Węzeł albo PustaLista) + Opcja (Trafienie albo
#   Pudło) — jak w analizatorze morfologicznym,
# - wynik operacji API: Skutek (Sukces albo Porażka) — dopasowanie `jest:`
#   wymusza obsłużenie obu gałęzi,
# - stan aplikacji mutowany zapisami do pól (chain-LHS), identyfikatory
#   nadaje licznik w stanie,
# - IO (sieć, dziennik, zegar, operacje tekstowe) zadeklarowane przez
#   `można` — sygnatury w całości jawne.

# ---------- kontenery ----------

definicja Węzła z elementem:
    głowa (element)
    ogon (Lista)

definicja PustejListy:
    znacznik (Liczba)

Lista to Węzeł albo PustaLista

definicja Trafienia z wartością:
    wartość (wartość)

definicja Pudła:
    powód (Tekst)

Opcja to Trafienie albo Pudło

# ---------- model domeny ----------

definicja Użytkownika:
    identyfikator (Liczba)
    nazwa (Tekst)
    obserwowani (Lista)

definicja Komentarza:
    autor (Liczba)
    tekst (Tekst)

definicja Postu:
    identyfikator (Liczba)
    autor (Liczba)
    treść (Tekst)
    chwila (Liczba)
    fani (Lista)
    komentarze (Lista)

definicja Stanu:
    użytkownicy (Lista)
    wpisy (Lista)
    licznik (Liczba)

definicja Sukcesu:
    opis (Tekst)

definicja Porażki:
    powód (Tekst)

Skutek to Sukces albo Porażka

# ---------- świat zewnętrzny ----------

można wysłać_odpowiedź tekst (Tekst) do klienta (Liczba) -> Nic
można zapisać_dziennik wpis (Tekst) -> Nic
można powiadamiać odbiorcę (Liczba) o nowości (Tekst) -> Nic
można pobrać_czas -> Liczba
można skleić tekst (Tekst) z drugim (Tekst) -> Tekst
można zakodować liczbę (Liczba) -> Tekst

# ---------- operacje na listach ----------

aby utworzyć_pustą:
    zwróć PustaLista o znaczniku zero

aby dodać element do listy:
    zwróć Węzeł o głowie element o ogonie lista

aby liczyć listę:
    lista jest:
        PustąListą:
            zwróć zero
        Węzłem z ogonem:
            zwróć jeden plus licz ogon

aby należeć element do zbioru:
    zbiór jest:
        PustąListą:
            zwróć zero równe jeden
        Węzłem z głową z ogonem:
            jeśli głowa równe element:
                zwróć zero równe zero
            zwróć należy element do ogona

# Wyszukiwanie rekordu po identyfikatorze. Dzięki wymazywaniu parametrów
# unii ta sama funkcja obsługuje listę użytkowników i listę postów —
# wystarczy, że element ma pole `identyfikator`.
aby wyszukiwać numer w rekordach:
    rekordy jest:
        PustąListą:
            zwróć Pudło o powodzie "nie znaleziono rekordu"
        Węzłem z głową z ogonem:
            jeśli identyfikator głowy równe numer:
                zwróć Trafienie o wartości głowa
            zwróć wyszukuj numer w ogonie

# ---------- operacje API (mutują stan, zwracają Skutek) ----------

aby zarejestrować nazwę w stanie:
    użytkownik to Użytkownik o identyfikatorze licznik stanu o nazwie nazwa o obserwowanych utwórz_pustą
    użytkownicy stanu to dodaj użytkownika do użytkowników stanu
    licznik stanu to licznik stanu plus jeden
    zapisz_dziennik (sklej "nowe konto: " z nazwą)
    zwróć Sukces o opisie "zarejestrowano"

aby opublikować treść przez autora w stanie:
    znalezisko to wyszukuj autora w użytkownikach stanu
    znalezisko jest:
        Pudłem z powodem:
            zwróć Porażka o powodzie powód
        Trafieniem:
            post to Post o identyfikatorze licznik stanu o autorze autor o treści treść o chwili pobierz_czas o fanach utwórz_pustą o komentarzach utwórz_pustą
            wpisy stanu to dodaj post do wpisów stanu
            licznik stanu to licznik stanu plus jeden
            zwróć Sukces o opisie "opublikowano"

aby polubić wpis przez fana w stanie:
    znalezisko to wyszukuj wpis we wpisach stanu
    znalezisko jest:
        Pudłem z powodem:
            zwróć Porażka o powodzie powód
        Trafieniem z wartością:
            jeśli należy fan do fanów wartości:
                zwróć Porażka o powodzie "już polubiono"
            fani wartości to dodaj fana do fanów wartości
            powiadamiaj autora wartości o "ktoś polubił twój post"
            zwróć Sukces o opisie "polubiono"

aby skomentować wpis przez autora słowami w stanie:
    znalezisko to wyszukuj wpis we wpisach stanu
    znalezisko jest:
        Pudłem z powodem:
            zwróć Porażka o powodzie powód
        Trafieniem z wartością:
            komentarz to Komentarz o autorze autor o tekście słowa
            komentarze wartości to dodaj komentarz do komentarzy wartości
            zwróć Sukces o opisie "skomentowano"

aby obserwować cel przez fana w stanie:
    znaleziony_fan to wyszukuj fana w użytkownikach stanu
    znaleziony_fan jest:
        Pudłem:
            zwróć Porażka o powodzie "obserwujący nie istnieje"
        Trafieniem z wartością:
            obserwujący to wartość
            znaleziony_cel to wyszukuj cel w użytkownikach stanu
            znaleziony_cel jest:
                Pudłem:
                    zwróć Porażka o powodzie "cel nie istnieje"
                Trafieniem z wartością:
                    jeśli należy identyfikator wartości do obserwowanych obserwującego:
                        zwróć Porażka o powodzie "już obserwuje"
                    obserwowani obserwującego to dodaj identyfikator wartości do obserwowanych obserwującego
                    zwróć Sukces o opisie "zaobserwowano"

# ---------- oś czasu ----------

aby zbierać posty dla obserwowanych:
    posty jest:
        PustąListą:
            zwróć posty
        Węzłem z głową z ogonem:
            reszta to zbieraj ogon dla obserwowanych
            jeśli należy autor głowy do obserwowanych:
                zwróć dodaj głowę do reszty
            zwróć resztę

aby opisywać posty:
    posty jest:
        PustąListą:
            zwróć ""
        Węzłem z głową z ogonem:
            zwróć sklej treść głowy z (opisuj ogon)

# ---------- obsługa odpowiedzi ----------

aby zgłaszać skutek do klienta:
    skutek jest:
        Sukcesem z opisem:
            wyślij_odpowiedź opis do klienta
        Porażką z powodem:
            zapisz_dziennik powód
            wyślij_odpowiedź powód do klienta

# ---------- przykładowa sesja ----------

aby działać:
    stan to Stan o użytkownikach utwórz_pustą o wpisach utwórz_pustą o liczniku jeden
    zgłaszaj (zarejestruj "ada" w stanie) do jeden
    zgłaszaj (zarejestruj "bob" w stanie) do dwa
    zgłaszaj (opublikuj "pierwszy post na osi" przez jeden w stanie) do jeden
    zgłaszaj (polub trzy przez dwa w stanie) do dwa
    zgłaszaj (skomentuj trzy przez dwa "ładne zdjęcie" w stanie) do dwa
    zgłaszaj (obserwuj jeden przez dwa w stanie) do dwa
    obserwator to wyszukuj dwa w użytkownikach stanu
    obserwator jest:
        Trafieniem z wartością:
            oś to zbieraj wpisy stanu dla obserwowanych wartości
            wyślij_odpowiedź (opisuj oś) do dwa
        Pudłem z powodem:
            zapisz_dziennik powód
    wyślij_odpowiedź (sklej "liczba rekordów: " z (zakoduj licz wpisy stanu)) do jeden
