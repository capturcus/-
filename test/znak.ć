# Literał znakowy: 'a' w pojedynczych cudzysłowach ma typ Znak — znak
# bierze się wprost z literału, bez wyłuskiwania głowy tekstu. Program
# paruje zasady DNA literałami, porównuje znaki między sobą i z głową
# tekstu-listy oraz wypisuje znaki wprost.

uwzględnij przygrywka.ć

aby sparować zasadę (Znak) -> Znak:
    jeśli zasada równa 'A':
        zwróć 'T'
    inaczej:
        jeśli zasada równa 'T':
            zwróć 'A'
        inaczej:
            zwróć zasada

aby działać:
    litera to 'ż'
    wypisz literę
    wypisz wynik sparowania 'A'
    wypisz wynik sparowania 'T'
    wypisz wynik sparowania 'x'
    sąd to litera równa 'ż'
    wypisz sąd
    sąd to litera równa 'z'
    wypisz sąd
    sąd to (wyłuskaj "żaba") równe literze
    wypisz sąd
