# Przygrywka: wspólne typy i operacje listowo-tekstowe. W module z
# przygrywką `Tekst` przestaje być typem wbudowanym — alias przesłania
# builtin i tekst staje się listą znaków. Literały tekstowe desugarują
# się w wykonaniu do łańcucha ogniw; pusty tekst ≡ Nic (świadoma decyzja).
#
# Funkcje listowe są generyczne po elemencie (niejawny parametr unii
# `element`): działają zarówno na Tekście (Lista o elemencie Znak), jak
# i na dowolnej innej liście. Wszystko rekurencyjnie i bez adnotacji
# poza tymi wymuszonymi przez granice (externy, samoreferencja).

definicja Ogniwa z elementem:
    głowa (element)
    ogon (Lista)

Lista to Ogniwo albo Nic

Tekst to Lista o elemencie Znak

# Rezultat — wynik operacji, która może się nie powieść. Wywołania
# z obsługą błędu (tryb przypuszczający + `?`, np. `wybrałbyś?`)
# wymagają unii dokładnie tego kształtu: odpakowują wartość Sukcesu,
# a Błąd propagują zwrotem z funkcji otaczającej. Sukces jest
# generyczny po elemencie; element konkretyzuje się przez użycie.
definicja Sukcesu z elementem:
    wartość (element)

definicja Błędu:
    opis (Tekst)

Rezultat to Sukces albo Błąd

# Wypis na standardowe wyjście — uniwersalny (przyjmuje cokolwiek:
# `Cokolwiek` to nieznana głowa typu, więc działa jak parametr typu).
# Wbudowany w interpreter; Tekst (lista znaków) drukuje się jako łańcuch,
# Nic jako "Nic", Przełącznik jako prawda/fałsz, struktury po polach.
można wypisać coś (Cokolwiek) -> Nic

# Arytmetyka spoza operatorów: dzielenie całkowitoliczbowe i reszta
# z dzielenia — wbudowane w interpreter (dzielenie podłogowe, reszta
# nieujemna dla dodatniego dzielnika; dzielenie przez zero to błąd
# wykonania). `podziel siedem przez dwa` → 3; `weź_resztę_z_dzielenia
# siedmiu przez dwa` → 1.
można podzielić pierwszą_liczbę (Liczba) przez drugą_liczbę (Liczba) -> Liczba

można wziąć_resztę_z_dzielenia pierwszej_liczby (Liczba) przez drugą_liczbę (Liczba) -> Liczba

# Most między Znakiem a jego punktem kodowym Unicode (jak `chr`/`ord`
# w Pythonie) — wbudowane w interpreter. Ć nie ma tablicy ASCII, więc
# to jedyna droga między znakiem a liczbą (porównania i arytmetyka
# działają wyłącznie na Liczbie). `zapisz_znakiem sześćdziesiąt pięć`
# → 'A'; `zapisz_liczbą 'A'` → 65. Punkt kodowy poza zakresem Unicode
# to błąd wykonania.
można zapisać_znakiem liczbę (Liczba) -> Znak

można zapisać_liczbą znak (Znak) -> Liczba

# Długość listy — liczba ogniw.
aby zmierzyć listę (Lista) -> Liczba:
    lista jest:
        Ogniwem z ogonem:
            zwróć jeden plus zmierz ogon
        Niczym:
            zwróć zero

# Sklejenie dwóch list: elementy pierwszej, potem drugiej.
# Dwa OGONOWE przebiegi przez `przełożyć` (trampolina TCO) zamiast
# rekursji budującej stos — skleja listy dowolnej długości.
aby skleić listę (Lista) z resztą (Lista) -> Lista:
    zwróć przełóż (przełóż listę na Nic) na resztę

# Odwrócenie listy przez akumulator (element po elemencie na przód).
aby przełożyć listę (Lista) na stos (Lista) -> Lista:
    lista jest:
        Ogniwem z głową z ogonem:
            zwróć przełóż ogon na (Ogniwo o głowie głowa o ogonie stos)
        Niczym:
            zwróć stos

aby odwrócić listę (Lista) -> Lista:
    zwróć przełóż listę na Nic

# Pierwszy znak tekstu. Tekst bywa pusty (≡ Nic), a Znak nie ma wartości
# neutralnej — dla pustego zwracamy znak zapytania (`wyłuskać "?"` kończy
# się natychmiast, bo "?" ma dokładnie jedno ogniwo).
aby wyłuskać tekst (Tekst) -> Znak:
    tekst jest:
        Ogniwem z głową:
            zwróć głowa
        inaczej:
            zwróć wyłuskać "?"

# Świat zewnętrzny: pliki — wbudowane w interpreter. Poprawny odczyt
# daje Sukces z tekstem pliku, poprawny zapis Sukces z liczbą zapisanych
# bajtów; niepowodzenie to Błąd z opisem.
można czytać_plik ze ścieżki (Tekst) -> Rezultat o elemencie Tekst

można zapisać_plik dla zawartości (Tekst) do ścieżki (Tekst) -> Rezultat o elemencie Liczba

# Fold prawostronny: złóż [a, b, c] z op z akc = op(a, op(b, op(c, akc))).
# Operacja to wartość funkcyjna (referencja gerundialna, np. `z dodawaniem`).
aby złożyć listę (Lista) z operacją z akumulatorem:
    lista jest:
        Ogniwem z głową z ogonem:
            reszta to złóż ogon z operacją z akumulatorem
            zwróć zastosuj operację z głową z resztą
        Niczym:
            zwróć akumulator

# Mapa: nowa lista z wynikami operacji na każdym elemencie.
aby przekształcać listę (Lista) z operacją:
    lista jest:
        Ogniwem z głową z ogonem:
            zwróć Ogniwo o głowie (zastosuj operację z głową) o ogonie (przekształcaj ogon z operacją)
        Niczym:
            zwróć Nic

# Filtr: zostają elementy, dla których warunek daje prawdę.
aby przesiewać listę (Lista) przez warunek:
    lista jest:
        Ogniwem z głową z ogonem:
            reszta to przesiewaj ogon przez warunek
            jeśli zastosuj warunek z głową:
                zwróć Ogniwo o głowie głowa o ogonie reszta
            zwróć resztę
        Niczym:
            zwróć Nic

# Indeksowanie listy (pozycje liczone od jednego): Sukces z elementem
aby wskazać pozycję na liście (Lista):
    lista jest:
        Ogniwem z głową z ogonem:
            jeśli pozycja równa jeden:
                zwróć Sukces o wartości głowa
            zwróć wskaż (pozycja minus jeden) na ogonie
        Niczym:
            zwróć Błąd o opisie "pozycja poza listą"

# Cyfra (0–9) jako znak — Ć nie ma tablicy ASCII, więc wprost.
aby przedstawić cyfrę (Liczba) -> Znak:
    jeśli cyfra równa zero:
        zwróć '0'
    jeśli cyfra równa jeden:
        zwróć '1'
    jeśli cyfra równa dwa:
        zwróć '2'
    jeśli cyfra równa trzy:
        zwróć '3'
    jeśli cyfra równa cztery:
        zwróć '4'
    jeśli cyfra równa pięć:
        zwróć '5'
    jeśli cyfra równa sześć:
        zwróć '6'
    jeśli cyfra równa siedem:
        zwróć '7'
    jeśli cyfra równa osiem:
        zwróć '8'
    zwróć '9'

# Nieujemna liczba cyfra po cyfrze, od najbardziej znaczącej.
aby rozwijać liczbę (Liczba) -> Tekst:
    jeśli liczba mniejsze od dziesięciu:
        zwróć Ogniwo o głowie (przedstaw liczbę) o ogonie Nic
    zwróć sklej (rozwijaj (podziel liczbę przez dziesięć)) z (Ogniwo o głowie (przedstaw (weź_resztę_z_dzielenia liczby przez dziesięć)) o ogonie Nic)

# Liczba jako tekst dziesiętny (z minusem dla ujemnych).
aby pokazać liczbę (Liczba) -> Tekst:
    jeśli liczba mniejsze od zero:
        zwróć sklej "-" z (rozwijaj (zero minus liczba))
    zwróć rozwijaj liczbę

# Quicksort (rosnąco, po `mniejsze od` — elementy to Liczby): oś to
# głowa; mniejsze przed nią, reszta (równe i większe) za nią.
aby wybrać_mniejsze od osi (Liczba) z listy (Lista) -> Lista:
    lista jest:
        Ogniwem z głową z ogonem:
            reszta to wybierz_mniejsze od osi z ogona
            jeśli głowa mniejsze od oś:
                zwróć Ogniwo o głowie głowa o ogonie reszta
            zwróć resztę
        Niczym:
            zwróć Nic

aby wybrać_resztę od osi (Liczba) z listy (Lista) -> Lista:
    lista jest:
        Ogniwem z głową z ogonem:
            reszta to wybierz_resztę od osi z ogona
            jeśli głowa mniejsze od oś:
                zwróć resztę
            zwróć Ogniwo o głowie głowa o ogonie reszta
        Niczym:
            zwróć Nic

aby sortować_szybko listę (Lista) -> Lista:
    lista jest:
        Ogniwem z głową z ogonem:
            zwróć sklej (sortuj_szybko (wybierz_mniejsze od głowy z ogona)) z (Ogniwo o głowie głowa o ogonie (sortuj_szybko (wybierz_resztę od głowy z ogona)))
        Niczym:
            zwróć Nic
