# Inspiracja: Flow recursive_defs — wzajemna rekursja bez deklaracji
# wyprzedzających (SCC typowane razem).

uwzględnij przygrywka.ć

aby sprawdzić_parzystość liczby:
    jeśli liczba równa zero:
        zwróć prawdę
    poprzednia to liczba minus jeden
    zwróć sprawdź_nieparzystość poprzedniej

aby sprawdzić_nieparzystość liczby:
    jeśli liczba równa zero:
        zwróć fałsz
    poprzednia to liczba minus jeden
    zwróć sprawdź_parzystość poprzedniej

aby działać:
    wypisz wynik sprawdzenia_parzystości dziesięciu
    wypisz wynik sprawdzenia_nieparzystości dziesięciu
