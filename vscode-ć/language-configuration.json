{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "wordPattern": "[a-z훳훶휌흢흦처힄탄탉A-Z훲훴휋흟흤횙힃탁탈_][a-z훳훶휌흢흦처힄탄탉A-Z훲훴휋흟흤횙힃탁탈0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^.*:\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
