      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#B33A4A"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#D4213D"
      }
    },
    {
      "scope": "keyword.control.cc",
      "settings": {
        "foreground": "#D4213D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.control.apply.cc",
      "settings": {
        "foreground": "#D4213D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.control.trycall.cc",
      "settings": {
        "foreground": "#D4213D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.function.cc",
      "settings": {
        "foreground": "#A4133C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.function.conditional.cc",
      "settings": {
        "foreground": "#E04F5F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.type.cc",
      "settings": {
        "foreground": "#7A0E22",
        "fontStyle": "bold"
      }
    },
    {
