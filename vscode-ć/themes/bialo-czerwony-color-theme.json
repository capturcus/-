{
  "name": "Ć — biało-czerwony",
  "type": "light",
  "semanticHighlighting": false,
  "colors": {
    "editor.background": "#FFFFFF",
    "editor.foreground": "#4A4A4A",
    "editorCursor.foreground": "#D4213D",
    "editor.selectionBackground": "#F8D7DA",
    "editor.lineHighlightBackground": "#FBF1F2",
    "editorLineNumber.foreground": "#D9C2C5",
    "editorLineNumber.activeForeground": "#D4213D",
    "editorIndentGuide.background1": "#F3E6E8",
    "editorIndentGuide.activeBackground1": "#E5B8BE",
    "editorWhitespace.foreground": "#F3E6E8",
    "statusBar.background": "#D4213D",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.noFolderBackground": "#D4213D",
    "activityBarBadge.background": "#D4213D",
    "activityBarBadge.foreground": "#FFFFFF",
    "tab.activeBorder": "#D4213D",
    "focusBorder": "#E5B8BE",
    "sideBar.background": "#FCFAFA",
    "panel.background": "#FFFFFF",
    "terminal.background": "#FFFFFF",
    "terminal.foreground": "#4A4A4A"
  },
  "tokenColors": [
