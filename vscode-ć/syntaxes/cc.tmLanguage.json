{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "훴",
  "scopeName": "source.cc",
  "patterns": [
    {
      "match": "^(uwzgl휌dnij)\\s+(\\S.*)$",
      "captures": {
        "1": {
          "name": "keyword.control.import.cc"
        },
        "2": {
          "name": "string.unquoted.path.cc"
        }
      }
    },
    {
      "name": "comment.line.number-sign.cc",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.double.cc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.cc",
          "match": "\\\\[nrt\\\\\"'0]"
        }
      ]
    },
    {
      "name": "string.quoted.single.cc",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.cc",
          "match": "\\\\[nrt\\\\\"'0]"
        }
      ]
    },
    {
      "match": "\\b(aby|mo탉na)\\s+([a-z훳훶휌흢흦처힄탄탉_][a-z훳훶휌흢흦처힄탄탉A-Z훲훴휋흟흤횙힃탁탈0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.control.cc"
        },
        "2": {
          "name": "entity.name.function.cc"
        }
      }
    },
    {
      "name": "entity.name.function.conditional.cc",
      "match": "\\b[a-z훳훶휌흢흦처힄탄탉_][a-z훳훶휌흢흦처힄탄탉A-Z훲훴휋흟흤횙힃탁탈0-9_]*(?:흢(?:a|o|y)?|li)by(?:m|힄|힄my|힄cie)?\\b"
    },
    {
      "name": "keyword.control.trycall.cc",
      "match": "\\?"
    },
    {
      "name": "keyword.control.cc",
      "match": "\\b(aby|mo탉na|definicja|je힄li|inaczej|dop처ki|dla|zwr처훶|zwr처ci훶|stop|dalej|albo|jest|s훳|to)\\b"
    },
    {
      "name": "keyword.control.apply.cc",
      "match": "\\b(zastosuj|zastosowa훶)\\b"
    },
    {
      "name": "constant.language.cc",
      "match": "\\b(prawd(a|휌|y|훳|o|zie)|fa흢sz(u|em|owi|e|ywie)?)\\b"
    },
    {
      "name": "constant.numeric.cc",
      "match": "\\b(zero|zera|zeru|zerem|zerze|jeden|jedna|jedno|jednego|jednej|jednym|jedn훳|dwa|dwie|dw처ch|dwom|dwoma|dwiema|trzy|trzech|trzem|trzema|cztery|czterech|czterem|czterema|pi휌훶|pi휌ciu|pi휌cioma|sze힄훶|sze힄ciu|sze힄cioma|siedem|siedmiu|siedmioma|osiem|o힄miu|o힄mioma|dziewi휌훶|dziewi휌ciu|dziewi휌cioma|dziesi휌훶|dziesi휌ciu|dziesi휌cioma|jedena힄cie|jedenastu|dwana힄cie|dwunastu|trzyna힄cie|trzynastu|czterna힄cie|czternastu|pi휌tna힄cie|pi휌tnastu|szesna힄cie|szesnastu|siedemna힄cie|siedemnastu|osiemna힄cie|osiemnastu|dziewi휌tna힄cie|dziewi휌tnastu|dwadzie힄cia|dwudziestu|trzydzie힄ci|trzydziestu|czterdzie힄ci|czterdziestu|pi휌훶dziesi훳t|pi휌훶dziesi휌ciu|sze힄훶dziesi훳t|sze힄훶dziesi휌ciu|siedemdziesi훳t|siedemdziesi휌ciu|osiemdziesi훳t|osiemdziesi휌ciu|dziewi휌훶dziesi훳t|dziewi휌훶dziesi휌ciu|sto|stu|dwie힄cie|dwustu|trzysta|trzystu|czterysta|czterystu|pi휌훶set|pi휌ciuset|sze힄훶set|sze힄ciuset|siedemset|siedmiuset|osiemset|o힄miuset|dziewi휌훶set|dziewi휌ciuset|tysi훳c|tysi훳ca|tysi훳ce|tysi휌cy|tysi훳cem|tysi훳cami|milion|miliona|miliony|milion처w|miliard|miliarda|miliardy|miliard처w)\\b"
    },
    {
      "name": "keyword.operator.comparison.cc",
      "match": "\\b(mniejsze|wi휌ksze)\\s+(od|r처wne)\\b|\\b(r처wne|nier처wne)\\b"
    },
    {
      "name": "keyword.operator.arithmetic.cc",
      "match": "\\b(plus|minus|razy)\\b"
    },
    {
      "name": "keyword.operator.logical.cc",
      "match": "\\b(i|lub|nie)\\b"
    },
    {
      "name": "entity.name.type.cc",
      "match": "\\b[A-Z훲훴휋흟흤횙힃탁탈][a-z훳훶휌흢흦처힄탄탉A-Z훲훴휋흟흤횙힃탁탈0-9_]*\\b"
    },
    {
      "name": "keyword.other.preposition.cc",
      "match": "\\b(z|ze|w|we|o|od|do|na|po|przez|przy|u|nad|za|bez|pod|mi휌dzy)\\b"
    }
  ]
}
